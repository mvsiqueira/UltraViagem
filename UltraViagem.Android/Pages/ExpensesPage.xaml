<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:vm="clr-namespace:UltraViagem.Android.ViewModels"
             xmlns:controls="clr-namespace:UltraViagem.Android.Controls"
             x:Class="UltraViagem.Android.Pages.ExpensesPage"
             Title="Gastos">

    <Grid RowDefinitions="*,Auto">

        <CollectionView Grid.Row="0"
                        ItemsSource="{Binding ExpenseGroups}"
                        IsGrouped="True"
                        Margin="16,4,16,8"
                        SelectionMode="None">

            <!-- Cabeçalho da categoria -->
            <CollectionView.GroupHeaderTemplate>
                <DataTemplate x:DataType="vm:ExpenseGroup">
                    <Grid ColumnDefinitions="Auto,*,Auto" Padding="2,16,2,6" ColumnSpacing="8">
                        <Path Grid.Column="0"
                              WidthRequest="20" HeightRequest="20" Aspect="Uniform"
                              VerticalOptions="Center"
                              Stroke="{Binding MarkerColor}" StrokeThickness="2"
                              StrokeLineCap="Round" StrokeLineJoin="Round"
                              Data="{Binding Icon}" />
                        <Label Grid.Column="1" Text="{Binding Name}"
                               FontAttributes="Bold" FontSize="14"
                               TextColor="{Binding HeaderColor}"
                               VerticalOptions="Center" />
                        <Label Grid.Column="2" Text="{Binding SubtotalLabel}"
                               FontAttributes="Bold" FontSize="13"
                               TextColor="{Binding HeaderColor}"
                               VerticalOptions="Center" />
                    </Grid>
                </DataTemplate>
            </CollectionView.GroupHeaderTemplate>

            <!-- Item de gasto (expansível) -->
            <CollectionView.ItemTemplate>
                <DataTemplate x:DataType="vm:ExpenseRow">
                    <Border BackgroundColor="{StaticResource Surface}"
                            Stroke="{StaticResource Border}"
                            StrokeShape="RoundRectangle 10"
                            StrokeThickness="1"
                            Padding="12,2" Margin="0,0,0,8">
                        <VerticalStackLayout>

                            <!-- Linha principal: toque expande, toque longo edita -->
                            <controls:LongPressBorder Stroke="Transparent" StrokeThickness="0"
                                                      BackgroundColor="Transparent" Padding="0"
                                                      Tapped="OnExpenseTapped"
                                                      LongPressed="OnExpenseLongPressed">
                                <Grid ColumnDefinitions="*,Auto" Padding="0,10" ColumnSpacing="8">
                                    <Grid.Triggers>
                                        <DataTrigger TargetType="Grid" Binding="{Binding IsActive}" Value="False">
                                            <Setter Property="Opacity" Value="0.4" />
                                        </DataTrigger>
                                    </Grid.Triggers>

                                    <VerticalStackLayout Grid.Column="0" Spacing="2" VerticalOptions="Center">
                                        <Label Text="{Binding Title}"
                                               FontSize="14"
                                               TextColor="{StaticResource TextPrimary}"
                                               LineBreakMode="TailTruncation" />
                                        <Label Text="{Binding StatusLabel}"
                                               FontSize="11"
                                               TextColor="{Binding StatusColor}" />
                                    </VerticalStackLayout>

                                    <Label Grid.Column="1"
                                           Text="{Binding ValueLabel}"
                                           FontSize="14" FontAttributes="Bold"
                                           TextColor="{StaticResource TextPrimary}"
                                           VerticalOptions="Center" />
                                </Grid>
                            </controls:LongPressBorder>

                            <!-- Detalhes (modo expandido) -->
                            <Border IsVisible="{Binding IsExpanded}"
                                    BackgroundColor="{StaticResource AppBackground}"
                                    Stroke="Transparent"
                                    StrokeShape="RoundRectangle 8"
                                    Padding="12" Margin="0,0,0,10">
                                <VerticalStackLayout Spacing="6">

                                    <Grid ColumnDefinitions="120,*" IsVisible="{Binding HasCompany}">
                                        <Label Grid.Column="0" Text="Fornecedor" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Column="1" Text="{Binding Company}" FontSize="12" TextColor="{StaticResource TextPrimary}" />
                                    </Grid>

                                    <Grid ColumnDefinitions="120,*">
                                        <Label Grid.Column="0" Text="Preço unit." FontSize="12" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Column="1" Text="{Binding PriceUnitLabel}" FontSize="12" TextColor="{StaticResource TextPrimary}" />
                                    </Grid>

                                    <Grid ColumnDefinitions="120,*">
                                        <Label Grid.Column="0" Text="Pessoas × Qtd" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Column="1" Text="{Binding PeopleQtyLabel}" FontSize="12" TextColor="{StaticResource TextPrimary}" />
                                    </Grid>

                                    <Grid ColumnDefinitions="120,*" IsVisible="{Binding ShowExchange}">
                                        <Label Grid.Column="0" Text="Câmbio" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Column="1" Text="{Binding ExchangeLabel}" FontSize="12" TextColor="{StaticResource TextPrimary}" />
                                    </Grid>

                                    <Grid ColumnDefinitions="120,*">
                                        <Label Grid.Column="0" Text="Pago" FontSize="12" TextColor="{StaticResource TextMuted}" />
                                        <Label Grid.Column="1" Text="{Binding PaidValueLabel}" FontSize="12" TextColor="{StaticResource TextPrimary}" />
                                    </Grid>

                                    <Label Text="{Binding Notes}" IsVisible="{Binding HasNotes}"
                                           FontSize="12" TextColor="{StaticResource TextMuted}" />

                                    <Label Text="Abrir reserva ›" IsVisible="{Binding HasLink}"
                                           FontSize="13" TextColor="{StaticResource Accent}"
                                           TextDecorations="Underline" Margin="0,2,0,0">
                                        <Label.GestureRecognizers>
                                            <TapGestureRecognizer Tapped="OnReservationLinkTapped" />
                                        </Label.GestureRecognizers>
                                    </Label>

                                </VerticalStackLayout>
                            </Border>

                        </VerticalStackLayout>
                    </Border>
                </DataTemplate>
            </CollectionView.ItemTemplate>

            <CollectionView.EmptyView>
                <Label Text="Nenhum gasto registrado"
                       Style="{StaticResource MutedLabel}"
                       HorizontalOptions="Center" Margin="0,40,0,0" />
            </CollectionView.EmptyView>
        </CollectionView>

        <!-- FAB: novo gasto -->
        <Button Grid.Row="0"
                Text="+"
                FontSize="26" FontAttributes="Bold"
                WidthRequest="56" HeightRequest="56"
                CornerRadius="28"
                HorizontalOptions="End" VerticalOptions="End"
                Margin="0,0,16,16"
                BackgroundColor="{StaticResource Accent}"
                TextColor="White"
                Clicked="OnAddTapped" />

        <!-- Cartão-resumo (rodapé) -->
        <Border Grid.Row="1"
                Style="{StaticResource CardFrame}"
                Margin="16,0,16,8"
                StrokeShape="RoundRectangle 12">
            <VerticalStackLayout Spacing="10">
                <Grid ColumnDefinitions="*,*,*" ColumnSpacing="8">
                    <VerticalStackLayout Grid.Column="0" Spacing="1">
                        <Label Text="ESTIMADO" FontSize="10" CharacterSpacing="0.6" TextColor="{StaticResource TextMuted}" />
                        <Label Text="{Binding TotalLabel}" FontSize="13" FontAttributes="Bold" TextColor="{StaticResource Accent}" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="1" Spacing="1">
                        <Label Text="PAGO" FontSize="10" CharacterSpacing="0.6" TextColor="{StaticResource TextMuted}" />
                        <Label Text="{Binding PaidLabel}" FontSize="13" FontAttributes="Bold" TextColor="#3B6D11" />
                    </VerticalStackLayout>
                    <VerticalStackLayout Grid.Column="2" Spacing="1">
                        <Label Text="A PAGAR" FontSize="10" CharacterSpacing="0.6" TextColor="{StaticResource TextMuted}" />
                        <Label Text="{Binding PendingLabel}" FontSize="13" FontAttributes="Bold" TextColor="#EF4444" />
                    </VerticalStackLayout>
                </Grid>
                <ProgressBar Progress="{Binding PaidFraction}" ProgressColor="{StaticResource Accent}" />
            </VerticalStackLayout>
        </Border>

    </Grid>
</ContentPage>
