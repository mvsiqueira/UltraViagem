<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UltraViagem.Android.Pages.TripPage"
             NavigationPage.HasNavigationBar="False">

    <Grid>

        <!-- ── LAYOUT PRINCIPAL ── -->
        <Grid RowDefinitions="56,*">

            <!-- Barra superior -->
            <Grid Grid.Row="0" ColumnDefinitions="56,*,56"
                  BackgroundColor="{StaticResource Surface}">
                <BoxView Grid.ColumnSpan="3" VerticalOptions="End"
                         HeightRequest="1" Color="{StaticResource Border}" />
                <Button Grid.Column="0"
                        Text="☰" FontSize="20" Padding="0"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextPrimary}"
                        Clicked="OnHamburgerClicked" />
                <Label Grid.Column="1" x:Name="ToolbarTitle"
                       VerticalOptions="Center" HorizontalOptions="Center"
                       FontSize="15" FontAttributes="Bold"
                       TextColor="{StaticResource TextPrimary}"
                       LineBreakMode="TailTruncation" />
                <Button Grid.Column="2"
                        Text="✕" FontSize="16" Padding="0"
                        BackgroundColor="Transparent"
                        TextColor="{StaticResource TextMuted}"
                        Clicked="OnCloseClicked" />
            </Grid>

            <!-- Área de conteúdo da seção atual -->
            <ContentView Grid.Row="1" x:Name="ContentArea" />

        </Grid>

        <!-- ── SCRIM (escurece o conteúdo quando o drawer abre) ── -->
        <BoxView x:Name="DrawerScrim"
                 BackgroundColor="#80000000"
                 Opacity="0" IsVisible="False">
            <BoxView.GestureRecognizers>
                <TapGestureRecognizer Tapped="OnScrimTapped" />
            </BoxView.GestureRecognizers>
        </BoxView>

        <!-- ── PAINEL LATERAL ── -->
        <Grid x:Name="DrawerPanel"
              WidthRequest="280"
              HorizontalOptions="Start"
              BackgroundColor="{StaticResource Surface}"
              TranslationX="-280">
            <VerticalStackLayout>

                <!-- Cabeçalho -->
                <Grid HeightRequest="160"
                      BackgroundColor="{StaticResource Accent}"
                      Padding="20,44,20,16">
                    <VerticalStackLayout VerticalOptions="Fill" Spacing="0">

                        <!-- Logo + nome do app na mesma linha -->
                        <HorizontalStackLayout Spacing="10" VerticalOptions="Start">
                            <Image Source="logo.png"
                                   HeightRequest="32" WidthRequest="32"
                                   VerticalOptions="Center" />
                            <Label Text="UltraViagem"
                                   TextColor="White"
                                   FontSize="22" FontAttributes="Bold"
                                   VerticalOptions="Center" />
                        </HorizontalStackLayout>

                        <!-- Nome da viagem -->
                        <Label x:Name="DrawerTripName"
                               TextColor="#CCffffff"
                               FontSize="12"
                               Margin="0,10,0,0"
                               LineBreakMode="TailTruncation" />

                    </VerticalStackLayout>
                </Grid>

                <!-- Itens de navegação -->
                <VerticalStackLayout Spacing="0" Padding="0,8,0,0">

                    <Grid ColumnDefinitions="4,*" HeightRequest="52">
                        <BoxView x:Name="Bar0" Grid.Column="0" BackgroundColor="{StaticResource Accent}" IsVisible="False" />
                        <Label x:Name="Label0" Grid.Column="1" Text="Visão Geral"
                               VerticalOptions="Center" Margin="20,0,0,0" FontSize="15"
                               TextColor="{StaticResource TextPrimary}" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavItemTapped" CommandParameter="0" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <Grid ColumnDefinitions="4,*" HeightRequest="52">
                        <BoxView x:Name="Bar1" Grid.Column="0" BackgroundColor="{StaticResource Accent}" IsVisible="False" />
                        <Label x:Name="Label1" Grid.Column="1" Text="Roteiro"
                               VerticalOptions="Center" Margin="20,0,0,0" FontSize="15"
                               TextColor="{StaticResource TextPrimary}" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavItemTapped" CommandParameter="1" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <Grid ColumnDefinitions="4,*" HeightRequest="52">
                        <BoxView x:Name="Bar2" Grid.Column="0" BackgroundColor="{StaticResource Accent}" IsVisible="False" />
                        <Label x:Name="Label2" Grid.Column="1" Text="Gastos"
                               VerticalOptions="Center" Margin="20,0,0,0" FontSize="15"
                               TextColor="{StaticResource TextPrimary}" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavItemTapped" CommandParameter="2" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <Grid ColumnDefinitions="4,*" HeightRequest="52">
                        <BoxView x:Name="Bar3" Grid.Column="0" BackgroundColor="{StaticResource Accent}" IsVisible="False" />
                        <Label x:Name="Label3" Grid.Column="1" Text="Dicas"
                               VerticalOptions="Center" Margin="20,0,0,0" FontSize="15"
                               TextColor="{StaticResource TextPrimary}" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavItemTapped" CommandParameter="3" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <Grid ColumnDefinitions="4,*" HeightRequest="52">
                        <BoxView x:Name="Bar4" Grid.Column="0" BackgroundColor="{StaticResource Accent}" IsVisible="False" />
                        <Label x:Name="Label4" Grid.Column="1" Text="Tarefas"
                               VerticalOptions="Center" Margin="20,0,0,0" FontSize="15"
                               TextColor="{StaticResource TextPrimary}" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavItemTapped" CommandParameter="4" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <Grid ColumnDefinitions="4,*" HeightRequest="52">
                        <BoxView x:Name="Bar5" Grid.Column="0" BackgroundColor="{StaticResource Accent}" IsVisible="False" />
                        <Label x:Name="Label5" Grid.Column="1" Text="Arquivos"
                               VerticalOptions="Center" Margin="20,0,0,0" FontSize="15"
                               TextColor="{StaticResource TextPrimary}" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnNavItemTapped" CommandParameter="5" />
                        </Grid.GestureRecognizers>
                    </Grid>

                    <!-- Exportar PDF -->
                    <BoxView HeightRequest="1" Color="{StaticResource Border}" Margin="20,8,20,8" />
                    <Grid ColumnDefinitions="4,*" HeightRequest="52">
                        <Label Grid.Column="1" Text="Exportar PDF"
                               VerticalOptions="Center" Margin="20,0,0,0" FontSize="15"
                               FontAttributes="Bold"
                               TextColor="{StaticResource Accent}" />
                        <Grid.GestureRecognizers>
                            <TapGestureRecognizer Tapped="OnExportPdfClicked" />
                        </Grid.GestureRecognizers>
                    </Grid>

                </VerticalStackLayout>
            </VerticalStackLayout>
        </Grid>

        <!-- ── OVERLAY "Gerando PDF" ── -->
        <Grid x:Name="BusyOverlay" BackgroundColor="#80000000" IsVisible="False">
            <VerticalStackLayout VerticalOptions="Center" HorizontalOptions="Center" Spacing="12">
                <ActivityIndicator IsRunning="True" Color="White" />
                <Label Text="Gerando PDF…" TextColor="White" FontSize="14" />
            </VerticalStackLayout>
        </Grid>

    </Grid>
</ContentPage>
