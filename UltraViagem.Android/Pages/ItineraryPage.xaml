<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:core="clr-namespace:UltraViagem.Core;assembly=UltraViagem.Core"
             x:Class="UltraViagem.Android.Pages.ItineraryPage"
             Title="Roteiro">

    <CollectionView ItemsSource="{Binding ActiveVersion.Itinerary}"
                    Margin="16,8">

        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="core:ItineraryDay">
                <VerticalStackLayout Spacing="6" Margin="0,0,0,16">

                    <!-- Cabeçalho do dia -->
                    <Grid ColumnDefinitions="40,*" ColumnSpacing="10">
                        <Frame Grid.Column="0"
                               BackgroundColor="{StaticResource AccentLight}"
                               BorderColor="Transparent"
                               CornerRadius="8" Padding="0"
                               HeightRequest="40" WidthRequest="40">
                            <Label Text="{Binding Title}"
                                   TextColor="{StaticResource Accent}"
                                   FontAttributes="Bold" FontSize="12"
                                   HorizontalOptions="Center"
                                   VerticalOptions="Center" />
                        </Frame>
                        <VerticalStackLayout Grid.Column="1" VerticalOptions="Center" Spacing="1">
                            <Label Text="{Binding Summary}"
                                   FontAttributes="Bold" FontSize="15"
                                   TextColor="{StaticResource TextPrimary}" />
                            <Label Text="{Binding Date, StringFormat='{0:ddd\, dd/MM/yyyy}'}"
                                   Style="{StaticResource MutedLabel}" FontSize="12" />
                        </VerticalStackLayout>
                    </Grid>

                    <!-- Chips das atividades -->
                    <FlexLayout BindableLayout.ItemsSource="{Binding Activities}"
                                Wrap="Wrap" Direction="Row" Gap="6">
                        <BindableLayout.ItemTemplate>
                            <DataTemplate x:DataType="core:ItineraryActivity">
                                <Frame CornerRadius="16"
                                       Padding="10,5"
                                       HasShadow="False"
                                       BorderColor="Transparent">
                                    <Frame.BackgroundColor>
                                        <Binding Path="Color"
                                                 Converter="{x:StaticResource HexToColor}" />
                                    </Frame.BackgroundColor>
                                    <Label Text="{Binding Title}"
                                           FontSize="12"
                                           LineBreakMode="NoWrap">
                                        <Label.TextColor>
                                            <Binding Path="Color"
                                                     Converter="{x:StaticResource HexToContrastColor}" />
                                        </Label.TextColor>
                                    </Label>
                                </Frame>
                            </DataTemplate>
                        </BindableLayout.ItemTemplate>
                    </FlexLayout>

                    <BoxView HeightRequest="1" Color="{StaticResource Border}" Margin="0,4,0,0" />

                </VerticalStackLayout>
            </DataTemplate>
        </CollectionView.ItemTemplate>

        <CollectionView.EmptyView>
            <Label Text="Nenhum dia no roteiro"
                   Style="{StaticResource MutedLabel}"
                   HorizontalOptions="Center"
                   Margin="0,40,0,0" />
        </CollectionView.EmptyView>

    </CollectionView>
</ContentPage>
