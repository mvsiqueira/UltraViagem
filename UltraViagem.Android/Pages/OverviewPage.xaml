<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="UltraViagem.Android.Pages.OverviewPage"
             Title="Visão Geral">

    <ScrollView Padding="16">
        <VerticalStackLayout Spacing="0">

            <!-- Título da viagem -->
            <Label Text="{Binding Trip.Title}"
                   FontSize="22" FontAttributes="Bold"
                   TextColor="{StaticResource Accent}"
                   Margin="0,8,0,4" />
            <Label Text="{Binding DurationLabel}"
                   Style="{StaticResource MutedLabel}"
                   Margin="0,0,0,18" />

            <!-- Grade 2x3 de blocos de seção -->
            <Grid ColumnDefinitions="*,*"
                  RowDefinitions="112,112,112"
                  ColumnSpacing="12" RowSpacing="12">

                <!-- Roteiro (teal) -->
                <Border Grid.Row="0" Grid.Column="0"
                        BackgroundColor="#E1F5EE" Stroke="Transparent"
                        StrokeShape="RoundRectangle 14" Padding="14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBlockTapped" CommandParameter="1" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Path Grid.Row="0" WidthRequest="26" HeightRequest="26" Aspect="Uniform"
                              HorizontalOptions="Start" VerticalOptions="Start"
                              Stroke="#0F6E56" StrokeThickness="2"
                              StrokeLineCap="Round" StrokeLineJoin="Round"
                              Data="M3 19a2 2 0 1 0 4 0a2 2 0 0 0 -4 0 M19 7a2 2 0 1 0 0 -4a2 2 0 0 0 0 4 M11 19h5.5a3.5 3.5 0 0 0 0 -7h-8a3.5 3.5 0 0 1 0 -7h4.5" />
                        <VerticalStackLayout Grid.Row="2" Spacing="1">
                            <Label Text="Roteiro" FontSize="16" FontAttributes="Bold" TextColor="#04342C" />
                            <Label Text="{Binding ItineraryInfo}" FontSize="12" TextColor="#0F6E56" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Tarefas (âmbar) -->
                <Border Grid.Row="0" Grid.Column="1"
                        BackgroundColor="#FAEEDA" Stroke="Transparent"
                        StrokeShape="RoundRectangle 14" Padding="14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBlockTapped" CommandParameter="4" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Path Grid.Row="0" WidthRequest="26" HeightRequest="26" Aspect="Uniform"
                              HorizontalOptions="Start" VerticalOptions="Start"
                              Stroke="#854F0B" StrokeThickness="2"
                              StrokeLineCap="Round" StrokeLineJoin="Round"
                              Data="M9.615 20h-2.615a2 2 0 0 1 -2 -2v-12a2 2 0 0 1 2 -2h8a2 2 0 0 1 2 2v8 M14 19l2 2l4 -4 M9 8h4 M9 12h2" />
                        <VerticalStackLayout Grid.Row="2" Spacing="1">
                            <Label Text="Tarefas" FontSize="16" FontAttributes="Bold" TextColor="#412402" />
                            <Label Text="{Binding TasksInfo}" FontSize="12" TextColor="#854F0B" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Mapa (azul) -->
                <Border Grid.Row="1" Grid.Column="0"
                        BackgroundColor="#E6F1FB" Stroke="Transparent"
                        StrokeShape="RoundRectangle 14" Padding="14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBlockTapped" CommandParameter="map" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Path Grid.Row="0" WidthRequest="26" HeightRequest="26" Aspect="Uniform"
                              HorizontalOptions="Start" VerticalOptions="Start"
                              Stroke="#185FA5" StrokeThickness="2"
                              StrokeLineCap="Round" StrokeLineJoin="Round"
                              Data="M9 11a3 3 0 1 0 6 0a3 3 0 0 0 -6 0 M17.657 16.657l-4.243 4.243a2 2 0 0 1 -2.827 0l-4.244 -4.243a8 8 0 1 1 11.314 0" />
                        <VerticalStackLayout Grid.Row="2" Spacing="1">
                            <Label Text="Mapa" FontSize="16" FontAttributes="Bold" TextColor="#042C53" />
                            <Label Text="{Binding MapInfo}" FontSize="12" TextColor="#185FA5" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Gastos (verde) -->
                <Border Grid.Row="1" Grid.Column="1"
                        BackgroundColor="#EAF3DE" Stroke="Transparent"
                        StrokeShape="RoundRectangle 14" Padding="14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBlockTapped" CommandParameter="2" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Path Grid.Row="0" WidthRequest="26" HeightRequest="26" Aspect="Uniform"
                              HorizontalOptions="Start" VerticalOptions="Start"
                              Stroke="#3B6D11" StrokeThickness="2"
                              StrokeLineCap="Round" StrokeLineJoin="Round"
                              Data="M7 15h-3a1 1 0 0 1 -1 -1v-8a1 1 0 0 1 1 -1h12a1 1 0 0 1 1 1v3 M7 10a1 1 0 0 1 1 -1h12a1 1 0 0 1 1 1v8a1 1 0 0 1 -1 1h-12a1 1 0 0 1 -1 -1l0 -8 M12 14a2 2 0 1 0 4 0a2 2 0 0 0 -4 0" />
                        <VerticalStackLayout Grid.Row="2" Spacing="1">
                            <Label Text="Gastos" FontSize="16" FontAttributes="Bold" TextColor="#173404" />
                            <Label Text="{Binding ExpensesInfo}" FontSize="12" TextColor="#3B6D11" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Dicas (roxo) -->
                <Border Grid.Row="2" Grid.Column="0"
                        BackgroundColor="#EEEDFE" Stroke="Transparent"
                        StrokeShape="RoundRectangle 14" Padding="14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBlockTapped" CommandParameter="3" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Path Grid.Row="0" WidthRequest="26" HeightRequest="26" Aspect="Uniform"
                              HorizontalOptions="Start" VerticalOptions="Start"
                              Stroke="#534AB7" StrokeThickness="2"
                              StrokeLineCap="Round" StrokeLineJoin="Round"
                              Data="M3 12h1m8 -9v1m8 8h1m-15.4 -6.4l.7 .7m12.1 -.7l-.7 .7 M9 16a5 5 0 1 1 6 0a3.5 3.5 0 0 0 -1 3a2 2 0 0 1 -4 0a3.5 3.5 0 0 0 -1 -3 M9.7 17l4.6 0" />
                        <VerticalStackLayout Grid.Row="2" Spacing="1">
                            <Label Text="Dicas" FontSize="16" FontAttributes="Bold" TextColor="#26215C" />
                            <Label Text="{Binding LinksInfo}" FontSize="12" TextColor="#534AB7" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

                <!-- Arquivos (coral) -->
                <Border Grid.Row="2" Grid.Column="1"
                        BackgroundColor="#FAECE7" Stroke="Transparent"
                        StrokeShape="RoundRectangle 14" Padding="14">
                    <Border.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnBlockTapped" CommandParameter="5" />
                    </Border.GestureRecognizers>
                    <Grid RowDefinitions="Auto,*,Auto">
                        <Path Grid.Row="0" WidthRequest="26" HeightRequest="26" Aspect="Uniform"
                              HorizontalOptions="Start" VerticalOptions="Start"
                              Stroke="#993C1D" StrokeThickness="2"
                              StrokeLineCap="Round" StrokeLineJoin="Round"
                              Data="M5 4h4l3 3h7a2 2 0 0 1 2 2v8a2 2 0 0 1 -2 2h-14a2 2 0 0 1 -2 -2v-11a2 2 0 0 1 2 -2" />
                        <VerticalStackLayout Grid.Row="2" Spacing="1">
                            <Label Text="Arquivos" FontSize="16" FontAttributes="Bold" TextColor="#4A1B0C" />
                            <Label Text="{Binding FilesInfo}" FontSize="12" TextColor="#993C1D" />
                        </VerticalStackLayout>
                    </Grid>
                </Border>

            </Grid>

        </VerticalStackLayout>
    </ScrollView>
</ContentPage>
