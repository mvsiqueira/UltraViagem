<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             xmlns:core="clr-namespace:UltraViagem.Core;assembly=UltraViagem.Core"
             x:Class="UltraViagem.Android.Pages.LinksPage"
             Title="Dicas">

    <CollectionView ItemsSource="{Binding Trip.Links}"
                    Margin="16,8"
                    SelectionMode="None">
        <CollectionView.ItemTemplate>
            <DataTemplate x:DataType="core:LinkItem">
                <Frame Style="{StaticResource CardFrame}">
                    <VerticalStackLayout Spacing="4">
                        <Label Text="{Binding Title}"
                               Style="{StaticResource TitleLabel}"
                               FontSize="14" />
                        <Label Text="{Binding Url}"
                               FontSize="12"
                               TextColor="#2563EB"
                               LineBreakMode="TailTruncation" />
                    </VerticalStackLayout>
                    <Frame.GestureRecognizers>
                        <TapGestureRecognizer Tapped="OnLinkTapped" />
                    </Frame.GestureRecognizers>
                </Frame>
            </DataTemplate>
        </CollectionView.ItemTemplate>
        <CollectionView.EmptyView>
            <Label Text="Nenhuma dica registrada"
                   Style="{StaticResource MutedLabel}"
                   HorizontalOptions="Center" Margin="0,40,0,0" />
        </CollectionView.EmptyView>
    </CollectionView>
</ContentPage>
