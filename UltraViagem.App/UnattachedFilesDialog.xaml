<Window x:Class="UltraViagem.App.UnattachedFilesDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Arquivos sem vínculo"
        Width="560"
        SizeToContent="Height"
        MaxHeight="560"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBackground}">
    <Border Style="{StaticResource Card}" Margin="18">
        <StackPanel>
            <TextBlock Text="Arquivos sem vínculo" FontSize="20" FontWeight="Bold" Margin="0,0,0,6" />
            <TextBlock x:Name="SubtitleText"
                       TextWrapping="Wrap"
                       Foreground="{StaticResource MutedTextBrush}"
                       Margin="0,0,0,16" />

            <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1"
                    CornerRadius="6" Margin="0,0,0,20">
                <ScrollViewer MaxHeight="240" VerticalScrollBarVisibility="Auto">
                    <ItemsControl x:Name="FileList" Margin="4">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <StackPanel Orientation="Horizontal" Margin="8,5">
                                    <TextBlock Text="&#xE8A5;"
                                               FontFamily="Segoe MDL2 Assets"
                                               FontSize="14"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               VerticalAlignment="Center"
                                               Margin="0,0,8,0" />
                                    <TextBlock Text="{Binding}"
                                               FontSize="13"
                                               VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis" />
                                </StackPanel>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Border>

            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="IgnoreButton" Content="Não fazer nada"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0" Click="Ignore_Click" />
                <Button x:Name="DeleteButton" Content="Excluir da pasta"
                        Style="{StaticResource SecondaryButton}"
                        Margin="0,0,8,0" Click="Delete_Click" />
                <Button x:Name="IncorporateButton" Content="Incorporar tudo"
                        Style="{StaticResource PrimaryButton}"
                        Click="Incorporate_Click" />
            </StackPanel>
        </StackPanel>
    </Border>
</Window>
