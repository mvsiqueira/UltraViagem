<Window x:Class="UltraViagem.App.TripSelectionWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Selecionar viagem"
        Width="980"
        Height="720"
        MinWidth="860"
        MinHeight="620"
        WindowStartupLocation="CenterOwner"
        Background="{StaticResource PageBackground}">
    <Border Style="{StaticResource Card}" Margin="18">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />
                <RowDefinition Height="*" />
                <RowDefinition Height="Auto" />
            </Grid.RowDefinitions>

            <Grid Margin="0,0,0,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Selecionar Viagem" FontSize="26" FontWeight="Bold" />
                    <TextBlock Text="Favoritas aparecem primeiro; as demais ficam agrupadas por ano." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                </StackPanel>
                <Button Grid.Column="1" Content="Nova Viagem" Style="{StaticResource PrimaryButton}" Click="NewTrip_Click" VerticalAlignment="Center" />
            </Grid>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <StackPanel>
                    <StackPanel x:Name="FavoritesSection" Margin="0,0,0,20">
                        <TextBlock Text="Favoritas" Style="{StaticResource SectionTitle}" />
                        <ItemsControl x:Name="FavoritesItems" Margin="0,10,0,0">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel />
                                </ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                        </ItemsControl>
                    </StackPanel>

                    <ItemsControl x:Name="YearGroupsItems" />
                </StackPanel>
            </ScrollViewer>

            <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                <Button Content="Cancelar" Style="{StaticResource SecondaryButton}" Click="Cancel_Click" />
            </StackPanel>
        </Grid>
    </Border>
</Window>
