<Window x:Class="UltraViagem.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:UltraViagem.App"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="UltraViagem"
        Height="900"
        MinHeight="760"
        Width="1360"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackground}">
    <Window.Resources>
        <Style x:Key="ClickableCardHeader" TargetType="Border">
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Background" Value="Transparent" />
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                </Trigger>
            </Style.Triggers>
        </Style>
        <local:AttachmentIconConverter x:Key="AttachmentIconConverter" />
        <local:AttachmentMetadataConverter x:Key="AttachmentMetadataConverter" />
        <Style x:Key="ColorSwatchButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Width" Value="22" />
            <Setter Property="Height" Value="22" />
            <Setter Property="MinHeight" Value="22" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
        </Style>
        <Style x:Key="IconPickerButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Width" Value="34" />
            <Setter Property="Height" Value="34" />
            <Setter Property="MinHeight" Value="34" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Margin" Value="2" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
        </Style>
        <Style x:Key="CardActionButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}">
                            <Border.Resources>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Style>
                            </Border.Resources>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#C8EDE8" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="CardAcceptButton" TargetType="Button" BasedOn="{StaticResource ButtonBase}">
            <Setter Property="Width" Value="26" />
            <Setter Property="Height" Value="26" />
            <Setter Property="MinHeight" Value="26" />
            <Setter Property="Padding" Value="0" />
            <Setter Property="Background" Value="{StaticResource AccentBrush}" />
            <Setter Property="Foreground" Value="White" />
            <Setter Property="HorizontalContentAlignment" Value="Center" />
            <Setter Property="VerticalContentAlignment" Value="Center" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Chrome"
                                Background="{TemplateBinding Background}"
                                CornerRadius="6"
                                TextElement.Foreground="{Binding Foreground, RelativeSource={RelativeSource TemplatedParent}}">
                            <Border.Resources>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                    <Setter Property="Foreground" Value="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                </Style>
                            </Border.Resources>
                            <ContentPresenter HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                              VerticalAlignment="{TemplateBinding VerticalContentAlignment}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="{StaticResource AccentHoverBrush}" />
                            </Trigger>
                            <Trigger Property="IsPressed" Value="True">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.85" />
                            </Trigger>
                            <Trigger Property="IsEnabled" Value="False">
                                <Setter TargetName="Chrome" Property="Opacity" Value="0.45" />
                                <Setter Property="Cursor" Value="Arrow" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
        <Style x:Key="ExpenseTabControl" TargetType="TabControl">
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding" Value="0" />
        </Style>
        <Style x:Key="ExpenseTabItem" TargetType="TabItem">
            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
            <Setter Property="FontFamily" Value="Segoe UI" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="FontWeight" Value="SemiBold" />
            <Setter Property="Padding" Value="15,8" />
            <Setter Property="Margin" Value="0,0,8,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TabItem">
                        <Border x:Name="Chrome"
                                Background="Transparent"
                                BorderBrush="Transparent"
                                BorderThickness="0,0,0,2"
                                CornerRadius="6,6,0,0"
                                MinWidth="58"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter ContentSource="Header"
                                              HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              RecognizesAccessKey="True" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#F5FCFA" />
                                <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                            </Trigger>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter TargetName="Chrome" Property="Background" Value="#F5FCFA" />
                                <Setter TargetName="Chrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="Auto" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border x:Name="SidebarBorder" Grid.Column="0" Width="220" Background="{StaticResource SidebarBackground}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,1,0">
            <DockPanel Margin="0,18" LastChildFill="False">
                <StackPanel DockPanel.Dock="Top">
                    <Button x:Name="LogoButton"
                            Click="ToggleSidebar_Click"
                            Background="Transparent"
                            BorderThickness="0"
                            Padding="14,0"
                            HorizontalContentAlignment="Left"
                            Cursor="Hand"
                            Margin="0,0,0,28">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="48" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <Image Source="Assets/AppIcon/app-icon.png"
                                   Width="38"
                                   Height="38"
                                   VerticalAlignment="Center"
                                   RenderOptions.BitmapScalingMode="HighQuality" />
                            <TextBlock Grid.Column="1"
                                       Text="UltraViagem"
                                       FontSize="20"
                                       FontWeight="Bold"
                                       VerticalAlignment="Center"
                                       Foreground="#0E4C49"
                                       Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}" />
                        </Grid>
                    </Button>

                    <Button x:Name="OverviewNavButton" Style="{StaticResource NavButton}" Click="ShowOverview_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Visão Geral" Style="{StaticResource NavLabel}" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="TripDetailsNavButton" Style="{StaticResource NavButton}" Click="EditTrip_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Dados da viagem" Style="{StaticResource NavLabel}" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="ItineraryNavButton" Style="{StaticResource NavButton}" Click="ShowItinerary_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8FD;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Roteiro" Style="{StaticResource NavLabel}" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="TasksNavButton" Style="{StaticResource NavButton}" Click="ShowTasks_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73A;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Tarefas" Style="{StaticResource NavLabel}" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="MapNavButton" Style="{StaticResource NavButton}" Click="ShowMap_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE707;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Mapa" Style="{StaticResource NavLabel}" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BudgetNavButton" Style="{StaticResource NavButton}" Click="ShowBudget_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="28" Height="28" Margin="0,3,0,0" VerticalAlignment="Center">
                                <Grid Width="24" Height="24">
                                    <Border Width="20" Height="14" CornerRadius="1.8" BorderBrush="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" BorderThickness="1.45" />
                                    <TextBlock Text="$" Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0" />
                                </Grid>
                            </Viewbox>
                            <TextBlock Text="Gastos" Style="{StaticResource NavLabel}" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="TipsNavButton" Style="{StaticResource NavButton}" Click="ShowTips_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8BD;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Dicas" Style="{StaticResource NavLabel}" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="FilesNavButton" Style="{StaticResource NavButton}" Click="ShowFiles_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Arquivos" Style="{StaticResource NavLabel}" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Button Style="{StaticResource NavButton}" IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Configurações" Style="{StaticResource NavLabel}" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="ShowAbout_Click">
                        <StackPanel Orientation="Horizontal">
                            <Viewbox Width="28"
                                     Height="28"
                                     Margin="0,3,0,0"
                                     VerticalAlignment="Center"
                                     Stretch="Uniform">
                                <Grid Width="24" Height="24">
                                    <Ellipse Width="18"
                                             Height="18"
                                             Stroke="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                             StrokeThickness="1.55"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center" />
                                    <Rectangle Width="1.6"
                                               Height="7"
                                               RadiusX="0.8"
                                               RadiusY="0.8"
                                               Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="0,-3,0,0" />
                                    <Ellipse Width="2.1"
                                             Height="2.1"
                                             Fill="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}"
                                             HorizontalAlignment="Center"
                                             VerticalAlignment="Center"
                                             Margin="0,7,0,0" />
                                </Grid>
                            </Viewbox>
                            <TextBlock Text="Sobre" Style="{StaticResource NavLabel}" Visibility="{Binding IsSidebarExpanded, Converter={StaticResource BoolToVisibility}}" />
                        </StackPanel>
                    </Button>
                    <Border x:Name="RepoExpandedPanel" Background="{StaticResource SidebarPanelBackground}" CornerRadius="8" Padding="12" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Repositório" Style="{StaticResource Caption}" />
                            <Button Style="{StaticResource LinkButton}" Click="OpenRepositoryFolder_Click" Margin="0,5,0,12" ToolTip="Abrir pasta do repositório">
                                <TextBlock Text="{Binding RootPath}" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource AccentBrush}" TextDecorations="Underline" />
                            </Button>
                            <Button Content="Selecionar Pasta" Style="{StaticResource SecondaryButton}" Click="SelectRepository_Click" />
                        </StackPanel>
                    </Border>
                    <Button x:Name="RepoCollapsedButton"
                            Style="{StaticResource NavButton}"
                            Click="OpenRepositoryFolder_Click"
                            ToolTip="Abrir pasta do repositório"
                            Margin="0,8,0,0"
                            Visibility="Collapsed">
                        <TextBlock Text="&#xE8DA;"
                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="22"
                                   Width="28"
                                   Height="28"
                                   TextAlignment="Center"
                                   LineStackingStrategy="BlockLineHeight"
                                   LineHeight="28"
                                   Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                    </Button>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="84" />
                <RowDefinition Height="*" />
                <RowDefinition Height="44" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Height="58"
                            Style="{StaticResource SecondaryButton}"
                            Background="#FFFEFB"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            Foreground="{StaticResource TextBrush}"
                            Padding="0"
                            Click="OpenTripSelection_Click"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Center"
                            Margin="-8,0,0,0">
                        <Grid Margin="12,0,14,0" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="26" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE821;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       FontSize="24" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TripTitle}" FontWeight="SemiBold" FontSize="14" TextAlignment="Left" />
                                <TextBlock Text="{Binding TripSubtitle}" Style="{StaticResource Caption}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="▼"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="14,2,0,0" />
                        </Grid>
                    </Button>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <Button Style="{StaticResource PrimaryButton}" Content="+  Nova Viagem" Click="NewTrip_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer x:Name="OverviewPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="24,22,24,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding TripTitle}" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" />
                                <Button Margin="8,3,0,0"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        Click="ToggleCurrentTripFavorite_Click">
                                    <TextBlock Text="{Binding CurrentTripFavoriteGlyph}"
                                               FontSize="24"
                                               FontWeight="Normal" />
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource LinkButton}">
                                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                            <Setter Property="ToolTip" Value="Marcar viagem como favorita" />
                                            <Style.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                                </Style>
                                            </Style.Resources>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentTripFavorite}" Value="True">
                                                    <Setter Property="ToolTip" Value="Remover viagem dos favoritos" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Button.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentTripFavorite}" Value="True">
                                                    <Setter Property="Foreground" Value="#E3A008" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="{Binding TripSubtitle}" Foreground="{StaticResource MutedTextBrush}" FontSize="14" Margin="0,4,0,0" />
                        </StackPanel>
                        <Button Grid.Column="1" Content="Exportar PDF"
                                Style="{StaticResource SecondaryButton}"
                                VerticalAlignment="Center"
                                Click="ExportPdf_Click" />
                    </Grid>

                    <Border Grid.Row="1" Margin="0,0,0,26">
                        <StackPanel>
                            <!-- Cabeçalho da seção -->
                            <Border Cursor="Hand" Margin="0,0,0,12" Padding="2,6" MouseLeftButtonDown="ShowItinerary_Header_Click">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="Transparent" />
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                            </Trigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <TextBlock FontSize="16">
                                    <Run Text="Roteiro" FontWeight="SemiBold" />
                                    <Run Text=" — Visão geral do dia a dia" Foreground="{StaticResource MutedTextBrush}" />
                                </TextBlock>
                            </Border>
                            <!-- Cards horizontais com scroll -->
                            <ScrollViewer x:Name="OverviewItineraryScroll"
                                          HorizontalScrollBarVisibility="Auto"
                                          VerticalScrollBarVisibility="Disabled"
                                          PreviewMouseWheel="OverviewItinerary_PreviewMouseWheel">
                                <ItemsControl ItemsSource="{Binding Itinerary}" Padding="2,4,2,8">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Top" />
                                        </ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <!-- Círculo numerado -->
                                                <Border Width="28" Height="28" CornerRadius="14"
                                                        Background="{StaticResource AccentBrush}"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Number}" Foreground="White"
                                                               FontSize="12" FontWeight="SemiBold"
                                                               HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                                <!-- Card do dia -->
                                                <Border Style="{StaticResource Card}" Width="210" Height="240" Padding="14"
                                                        Margin="8,0,12,0" Cursor="Hand" ClipToBounds="True"
                                                        TextElement.FontFamily="Calibri"
                                                        TextOptions.TextFormattingMode="Display"
                                                        MouseLeftButtonDown="OverviewDayCard_Click">
                                                    <Grid>
                                                        <Grid.RowDefinitions>
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="Auto" />
                                                            <RowDefinition Height="*" />
                                                        </Grid.RowDefinitions>
                                                        <!-- Título + data -->
                                                        <Grid Grid.Row="0" Margin="0,0,0,10">
                                                            <TextBlock Text="{Binding Title}" FontSize="15"
                                                                       FontWeight="SemiBold"
                                                                       TextTrimming="CharacterEllipsis" />
                                                            <TextBlock Text="{Binding DateLabel}"
                                                                       Style="{StaticResource Caption}"
                                                                       HorizontalAlignment="Right"
                                                                       VerticalAlignment="Center" />
                                                        </Grid>
                                                        <!-- Imagem + resumo/pernoite -->
                                                        <Grid Grid.Row="1" Margin="0,0,0,10">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="68" />
                                                                <ColumnDefinition Width="*" />
                                                            </Grid.ColumnDefinitions>
                                                            <Border Width="60" Height="60" CornerRadius="6"
                                                                    Background="{StaticResource AccentSoftBrush}"
                                                                    ClipToBounds="True">
                                                                <Grid>
                                                                    <TextBlock Text="🗺" FontFamily="Segoe UI Emoji"
                                                                               FontSize="26" HorizontalAlignment="Center"
                                                                               VerticalAlignment="Center">
                                                                        <TextBlock.Style>
                                                                            <Style TargetType="TextBlock">
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding HasCoverImage}" Value="True">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </TextBlock.Style>
                                                                    </TextBlock>
                                                                    <Image Source="{Binding CoverImage}" Stretch="UniformToFill"
                                                                           Visibility="{Binding HasCoverImage, Converter={StaticResource BoolToVisibility}}" />
                                                                    <!-- Botão de reload: overlay invisível, aparece no hover -->
                                                                    <Button Width="60" Height="60" Padding="0"
                                                                            Click="ReloadCoverImage_Click"
                                                                            Cursor="Hand" ToolTip="Recarregar imagem">
                                                                        <Button.Style>
                                                                            <Style TargetType="Button">
                                                                                <Setter Property="Opacity" Value="0" />
                                                                                <Setter Property="Background" Value="Transparent" />
                                                                                <Setter Property="BorderThickness" Value="0" />
                                                                                <Setter Property="Template">
                                                                                    <Setter.Value>
                                                                                        <ControlTemplate TargetType="Button">
                                                                                            <Border Background="{TemplateBinding Background}" CornerRadius="6">
                                                                                                <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                                            </Border>
                                                                                        </ControlTemplate>
                                                                                    </Setter.Value>
                                                                                </Setter>
                                                                                <Style.Triggers>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter Property="Opacity" Value="1" />
                                                                                        <Setter Property="Background" Value="#AA000000" />
                                                                                    </Trigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Button.Style>
                                                                        <TextBlock Text="↻" Foreground="White"
                                                                                   FontSize="20" FontWeight="SemiBold" />
                                                                    </Button>
                                                                </Grid>
                                                            </Border>
                                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="8,0,0,0">
                                                                <TextBlock Text="{Binding CardTitle}"
                                                                           FontWeight="SemiBold" TextWrapping="Wrap"
                                                                           FontSize="12" MaxHeight="36"
                                                                           TextTrimming="CharacterEllipsis" />
                                                                <Grid Margin="0,4,0,0"
                                                                      Visibility="{Binding HasPernoite, Converter={StaticResource BoolToVisibility}}">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="Auto" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <TextBlock Grid.Column="0" Text="🛏" FontFamily="Segoe UI Emoji"
                                                                               FontSize="10" VerticalAlignment="Top"
                                                                               Foreground="{StaticResource MutedTextBrush}"
                                                                               Margin="0,0,3,0" />
                                                                    <TextBlock Grid.Column="1" Text="{Binding PernoiteLabel}"
                                                                               Style="{StaticResource Caption}"
                                                                               TextWrapping="Wrap" />
                                                                </Grid>
                                                            </StackPanel>
                                                        </Grid>
                                                        <!-- Divisor -->
                                                        <Border Grid.Row="2" BorderBrush="{StaticResource BorderBrushSoft}"
                                                                BorderThickness="0,1,0,0" Margin="0,0,0,8" />
                                                        <!-- Atividades: preenche espaço restante e clipa o excesso -->
                                                        <ItemsControl Grid.Row="3" ItemsSource="{Binding TopActivities}" ClipToBounds="True">
                                                            <ItemsControl.ItemTemplate>
                                                                <DataTemplate>
                                                                    <Grid Margin="0,0,0,5">
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="20" />
                                                                            <ColumnDefinition Width="*" />
                                                                        </Grid.ColumnDefinitions>
                                                                        <TextBlock Grid.Column="0"
                                                                                   Text="{Binding OverviewIcon}"
                                                                                   FontFamily="Segoe UI Emoji"
                                                                                   FontSize="11"
                                                                                   VerticalAlignment="Center" />
                                                                        <TextBlock Grid.Column="1"
                                                                                   Text="{Binding OverviewTitle}"
                                                                                   FontSize="11"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   VerticalAlignment="Center" />
                                                                    </Grid>
                                                                </DataTemplate>
                                                            </ItemsControl.ItemTemplate>
                                                        </ItemsControl>
                                                    </Grid>
                                                </Border>
                                            </StackPanel>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </ScrollViewer>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.12*" />
                            <ColumnDefinition Width="1.12*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource ClickableCardHeader}" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrushSoft}" Margin="-18,-18,-18,8" Padding="18,0,18,0" MinHeight="48" MouseLeftButtonDown="ShowTasks_Header_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE73A;" Style="{StaticResource SectionIcon}" />
                                        <TextBlock Text="Tarefas" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Tasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding IsDone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding Title}" TextWrapping="Wrap" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                    <Setter Property="Foreground" Value="#8B928F" />
                                                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                                <TextBlock Grid.Row="1"
                                           Text="Nenhuma tarefa cadastrada."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding Tasks.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <StackPanel>
                                <Border Style="{StaticResource ClickableCardHeader}" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrushSoft}" Margin="-18,-18,-18,8" Padding="18,0,18,0" MinHeight="48" MouseLeftButtonDown="ShowBudget_Header_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <Viewbox Width="24" Height="24" Margin="0,1,9,0" VerticalAlignment="Center">
                                            <Grid Width="24" Height="24">
                                                <Border Width="20" Height="14" CornerRadius="1.8" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.45" />
                                                <TextBlock Text="$" Foreground="{StaticResource AccentBrush}" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0" />
                                            </Grid>
                                        </Viewbox>
                                        <TextBlock Text="Gastos" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="7" Padding="12,10" Margin="0,0,0,16">
                                    <UniformGrid Columns="3">
                                        <StackPanel>
                                            <TextBlock Text="Total estimado" Style="{StaticResource Caption}" />
                                            <TextBlock Text="{Binding EstimatedTotal}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="14" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Pago" Style="{StaticResource Caption}" />
                                            <TextBlock Text="{Binding PaidTotal}" Foreground="#15803D" FontWeight="Bold" FontSize="14" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="Pendente" Style="{StaticResource Caption}" />
                                            <TextBlock Text="{Binding PendingTotal}" Foreground="#B42318" FontWeight="Bold" FontSize="14" />
                                        </StackPanel>
                                    </UniformGrid>
                                </Border>
                                <TextBlock Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Text" Value="Por categoria" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BudgetCategories.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                                <ItemsControl ItemsSource="{Binding BudgetCategories}">
                                    <ItemsControl.Style>
                                        <Style TargetType="ItemsControl">
                                            <Style.Triggers>
                                                <Trigger Property="HasItems" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </Trigger>
                                            </Style.Triggers>
                                        </Style>
                                    </ItemsControl.Style>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="94" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="84" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                <Border Grid.Column="1" Background="#E8E2D7" CornerRadius="4" Height="12" VerticalAlignment="Center">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="{Binding BarGridLength}" />
                                                            <ColumnDefinition Width="{Binding FillGridLength}" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Background="{StaticResource AccentBrush}" CornerRadius="4" />
                                                    </Grid>
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding TotalLabel}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                                <TextBlock Text="Nenhum gasto cadastrado."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           Margin="0,8">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding BudgetCategories.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <StackPanel>
                                <Border Style="{StaticResource ClickableCardHeader}" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrushSoft}" Margin="-18,-18,-18,8" Padding="18,0,18,0" MinHeight="48" MouseLeftButtonDown="ShowMap_Header_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE707;" Style="{StaticResource SectionIcon}" />
                                        <TextBlock Text="Mapa" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>
                                <wv2:WebView2 x:Name="OverviewMapBrowser" Height="250" Margin="0,0,0,12"
                                              Visibility="{Binding HasMyMapsUrl, Converter={StaticResource BoolToVisibility}}"
                                              NavigationCompleted="OverviewMapBrowser_NavigationCompleted" />
                                <Button Content="Abrir no navegador" Style="{StaticResource SecondaryButton}" Click="OpenMyMaps_Click"
                                        Visibility="{Binding HasMyMapsUrl, Converter={StaticResource BoolToVisibility}}" />
                                <TextBlock x:Name="OverviewMapPlaceholder"
                                           Text="Nenhum mapa configurado."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           Margin="0,16">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasMyMapsUrl}" Value="False">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                    </Grid>

                    <Grid Grid.Row="3" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0" MinHeight="250">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource ClickableCardHeader}" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrushSoft}" Margin="-18,-18,-18,8" Padding="18,0,18,0" MinHeight="48" MouseLeftButtonDown="ShowTips_Header_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE8BD;" Style="{StaticResource SectionIcon}" />
                                        <TextBlock Text="Dicas" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,8,0" PreviewMouseWheel="OverviewCard_PreviewMouseWheel">
                                    <ItemsControl ItemsSource="{Binding OverviewTips}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="0,7" Margin="0,0,0,1">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                        <Grid>
                                                            <Button x:Name="OverviewTipLinkButton"
                                                                    Style="{StaticResource LinkButton}"
                                                                    Click="OpenTipLink_Click"
                                                                    ToolTip="Abrir link">
                                                                <TextBlock Text="{Binding Url}" Foreground="{StaticResource AccentBrush}" FontSize="12" TextWrapping="Wrap" />
                                                            </Button>
                                                            <TextBlock x:Name="OverviewTipText"
                                                                       Text="{Binding Url}"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap"
                                                                       Visibility="Collapsed" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding HasValidUrl}" Value="False">
                                                        <Setter TargetName="OverviewTipLinkButton" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="OverviewTipText" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock Grid.Row="1"
                                           Text="Nenhuma dica cadastrada."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding OverviewTips.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" MinHeight="250">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Border Grid.Row="0" Style="{StaticResource ClickableCardHeader}" BorderThickness="0,0,0,1" BorderBrush="{StaticResource BorderBrushSoft}" Margin="-18,-18,-18,8" Padding="18,0,18,0" MinHeight="48" MouseLeftButtonDown="ShowFiles_Header_Click">
                                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                        <TextBlock Text="&#xE8B7;" Style="{StaticResource SectionIcon}" />
                                        <TextBlock Text="Arquivos" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                </Border>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,8,0" PreviewMouseWheel="OverviewCard_PreviewMouseWheel">
                                    <ItemsControl ItemsSource="{Binding OverviewFiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border Padding="0,8" Margin="0,0,0,1">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="44" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="34" Height="38" CornerRadius="4" Background="#F7F9F8">
                                                            <Image Width="30" Height="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource AttachmentIconConverter}">
                                                                        <Binding Path="File" />
                                                                        <Binding Path="DataContext.TripPath" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding File}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,2,0,0">
                                                                <TextBlock.Text>
                                                                    <MultiBinding Converter="{StaticResource AttachmentMetadataConverter}">
                                                                        <Binding Path="File" />
                                                                        <Binding Path="DataContext.TripPath" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                                <TextBlock Grid.Row="1"
                                           Text="Nenhum arquivo anexado."
                                           Foreground="{StaticResource MutedTextBrush}"
                                           FontSize="13"
                                           HorizontalAlignment="Center"
                                           VerticalAlignment="Center">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                            <Setter Property="Visibility" Value="Collapsed" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding OverviewFiles.Count}" Value="0">
                                                    <Setter Property="Visibility" Value="Visible" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>

                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <Grid x:Name="TripDetailsPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18">
                <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,16">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE713;" Style="{StaticResource PanelTitleIcon}" />
                                        <TextBlock Text="Dados da viagem" Style="{StaticResource PanelTitleText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Edite as informações gerais da viagem atual." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" ToolTip="Voltar para visão geral" />
                            </StackPanel>
                        </Grid>

                        <Border Grid.Row="1" Style="{StaticResource Card}">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.ColumnSpan="2">
                                <TextBlock Text="Nome" Style="{StaticResource Caption}" />
                                <TextBox x:Name="TripDetailsTitleBox" Padding="10" FontSize="16" Margin="0,4,0,14" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,14,0">
                                <TextBlock Text="Data inicial" Style="{StaticResource Caption}" />
                                <DatePicker x:Name="TripDetailsStartDatePicker" Margin="0,4,0,14" Height="34" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Text="Data final" Style="{StaticResource Caption}" />
                                <TextBox x:Name="TripDetailsEndDateLabel" IsReadOnly="True"
                                         Height="34" Margin="0,4,0,14" IsTabStop="False" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,0,14,0">
                                <TextBlock Text="Pessoas" Style="{StaticResource Caption}" />
                                <TextBox x:Name="TripDetailsPeopleBox" Height="34" Margin="0,4,0,14" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="1">
                                <TextBlock Text="Moeda base" Style="{StaticResource Caption}" />
                                <TextBox x:Name="TripDetailsCurrencyBox" Height="34" Margin="0,4,0,14" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Margin="0,0,14,14">
                                <TextBlock Text="Blocos por dia (roteiro)" Style="{StaticResource Caption}" />
                                <TextBox x:Name="TripDetailsSlotsPerDayBox" Height="34" Margin="0,4,0,0" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.Column="1" Margin="0,0,0,14">
                                <TextBlock Text="Casas decimais para cotações" Style="{StaticResource Caption}" />
                                <TextBox x:Name="TripDetailsRateDecimalDigitsBox" Height="34" Margin="0,4,0,0" />
                            </StackPanel>

                            <!-- Grid do roteiro -->
                            <StackPanel Grid.Row="4" Grid.ColumnSpan="2" Orientation="Horizontal" Margin="0,0,0,14">
                                <CheckBox x:Name="TripDetailsGridCheckBox" VerticalAlignment="Center" />
                                <TextBlock Text="Exibir grid no roteiro" Margin="8,0,0,0" VerticalAlignment="Center" />
                            </StackPanel>

                            <StackPanel Grid.Row="5" Grid.ColumnSpan="2" Margin="0,14,0,14">
                                <TextBlock Text="Pasta da viagem" Style="{StaticResource Caption}" />
                                <TextBox x:Name="TripDetailsPathBox"
                                         Margin="0,4,0,0"
                                         IsReadOnly="True"
                                         MinWidth="620"
                                         Height="34"
                                         TextWrapping="NoWrap"
                                         ToolTip="{Binding TripPath}" />
                            </StackPanel>

                            <TextBlock Grid.Row="6"
                                       Grid.ColumnSpan="2"
                                       x:Name="TripDetailsErrorText"
                                       Foreground="#B42318"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                        </Grid>
                        </Border>

                        <DockPanel Grid.Row="2" Margin="0,18,0,0" LastChildFill="False">
                            <Button Content="Excluir Viagem" DockPanel.Dock="Left" Style="{StaticResource DangerButton}" Click="DeleteTrip_Click" />
                            <Button Content="Salvar Dados" DockPanel.Dock="Right" Style="{StaticResource PrimaryButton}" Click="SaveTripDetails_Click" />
                            <Button Content="Copiar Viagem" DockPanel.Dock="Right" Style="{StaticResource SecondaryButton}" Click="CopyTrip_Click" Margin="0,0,10,0" />
                        </DockPanel>
                    </Grid>
            </Grid>

            <Grid x:Name="BudgetPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18">
                <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,12">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <StackPanel Orientation="Horizontal">
                                <Viewbox Width="28" Height="34" Margin="0,8,8,0" VerticalAlignment="Top">
                                    <Grid Width="24" Height="24">
                                        <Border Width="20" Height="14" CornerRadius="1.8" BorderBrush="{StaticResource AccentBrush}" BorderThickness="1.45" />
                                        <TextBlock Text="$" Foreground="{StaticResource AccentBrush}" FontFamily="Segoe UI" FontSize="11" FontWeight="SemiBold" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-1,0,0" />
                                    </Grid>
                                </Viewbox>
                                <TextBlock Text="Gastos" Style="{StaticResource PanelTitleText}" />
                            </StackPanel>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="+  Novo Gasto" Style="{StaticResource SecondaryButton}" Height="34" Click="AddExpense_Click" Margin="0,0,8,0" />
                                <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" ToolTip="Voltar para visão geral" />
                            </StackPanel>
                            <TextBlock Grid.Row="1" Text="Registre e acompanhe os gastos estimados e realizados da viagem." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                        </Grid>

                        <TabControl Grid.Row="1"
                                    Style="{StaticResource ExpenseTabControl}"
                                    ItemContainerStyle="{StaticResource ExpenseTabItem}">
                            <TabItem Header="Itens">
                                <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,12,0,0">
                                    <ItemsControl x:Name="ExpenseGroupsList"
                                                  ItemsSource="{Binding ExpenseGroups}"
                                                  AllowDrop="True"
                                                  PreviewMouseLeftButtonDown="ExpenseGroupsList_PreviewMouseLeftButtonDown"
                                                  PreviewMouseMove="ExpenseGroupsList_PreviewMouseMove"
                                                  DragOver="ExpenseGroupsList_DragOver"
                                                  Drop="ExpenseGroupsList_Drop">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <StackPanel Margin="0,0,0,12">
                                            <Grid Margin="0,0,0,6" Tag="GroupHeader" Cursor="SizeAll">
                                                <TextBlock Text="{Binding Name}" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource AccentBrush}" />
                                                <TextBlock Text="{Binding TotalLabel}" HorizontalAlignment="Right" Foreground="{StaticResource MutedTextBrush}" FontWeight="SemiBold" />
                                            </Grid>
                                            <ItemsControl ItemsSource="{Binding Items}">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                                                BorderThickness="1"
                                                                CornerRadius="7"
                                                                Padding="8"
                                                                Margin="0,0,0,6"
                                                                MouseLeftButtonDown="SelectExpenseCard_MouseLeftButtonDown">
                                                            <Border.Style>
                                                                <Style TargetType="Border">
                                                                    <Setter Property="Background" Value="{StaticResource PanelBackground}" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding IsSelectedForEdit}" Value="True">
                                                                            <Setter Property="Background" Value="#F5FCFA" />
                                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                                        </DataTrigger>
                                                                        <DataTrigger Binding="{Binding IsActive}" Value="False">
                                                                            <Setter Property="Opacity" Value="0.72" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </Border.Style>
                                                            <Grid>
                                                                <Grid.RowDefinitions>
                                                                    <RowDefinition Height="Auto" />
                                                                    <RowDefinition Height="Auto" />
                                                                </Grid.RowDefinitions>
                                                                <Grid.ColumnDefinitions>
                                                                    <ColumnDefinition Width="2*" MinWidth="260" />
                                                                    <ColumnDefinition Width="2.2*" MinWidth="280" />
                                                                    <ColumnDefinition Width="1.25*" MinWidth="230" />
                                                                </Grid.ColumnDefinitions>
                                                                <Border x:Name="ExpenseSelectionRail"
                                                                        Grid.RowSpan="2"
                                                                        Grid.ColumnSpan="3"
                                                                        Width="4"
                                                                        Margin="-8,-8,0,-8"
                                                                        HorizontalAlignment="Left"
                                                                        Background="{StaticResource AccentBrush}"
                                                                        CornerRadius="7,0,0,7"
                                                                        Visibility="Collapsed" />

                                                                <Grid Margin="0,0,18,0" VerticalAlignment="Center">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="56" />
                                                                        <ColumnDefinition Width="*" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <ToggleButton IsChecked="{Binding IsActive, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                                  HorizontalAlignment="Left"
                                                                                  VerticalAlignment="Center"
                                                                                  Width="44"
                                                                                  Height="24"
                                                                                  Cursor="Hand"
                                                                                  ToolTip="{Binding ActiveStatusLabel}">
                                                                        <ToggleButton.Template>
                                                                            <ControlTemplate TargetType="ToggleButton">
                                                                                <Border x:Name="Track"
                                                                                        Width="44"
                                                                                        Height="24"
                                                                                        CornerRadius="12"
                                                                                        Background="#E8E6E0">
                                                                                    <Border x:Name="Knob"
                                                                                            Width="20"
                                                                                            Height="20"
                                                                                            CornerRadius="10"
                                                                                            Background="#FFFFFF"
                                                                                            HorizontalAlignment="Left"
                                                                                            Margin="2"
                                                                                            Effect="{x:Null}" />
                                                                                </Border>
                                                                                <ControlTemplate.Triggers>
                                                                                    <Trigger Property="IsChecked" Value="True">
                                                                                        <Setter TargetName="Track" Property="Background" Value="{StaticResource AccentBrush}" />
                                                                                        <Setter TargetName="Knob" Property="HorizontalAlignment" Value="Right" />
                                                                                    </Trigger>
                                                                                    <Trigger Property="IsMouseOver" Value="True">
                                                                                        <Setter TargetName="Track" Property="Opacity" Value="0.9" />
                                                                                    </Trigger>
                                                                                </ControlTemplate.Triggers>
                                                                            </ControlTemplate>
                                                                        </ToggleButton.Template>
                                                                    </ToggleButton>
                                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                                        <TextBlock x:Name="ExpenseTitleText" Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis" />
                                                                        <Button x:Name="ExpenseTitleLink"
                                                                                Visibility="Collapsed"
                                                                                Padding="0"
                                                                                HorizontalContentAlignment="Left"
                                                                                ToolTip="Abrir link do gasto"
                                                                                Click="OpenExpenseLink_Click">
                                                                            <Button.Style>
                                                                                <Style TargetType="Button" BasedOn="{StaticResource LinkButton}">
                                                                                    <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
                                                                                    <Style.Triggers>
                                                                                        <Trigger Property="IsMouseOver" Value="True">
                                                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                                                        </Trigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Button.Style>
                                                                            <TextBlock Text="{Binding Title}"
                                                                                       FontSize="14"
                                                                                       FontWeight="SemiBold"
                                                                                       TextTrimming="CharacterEllipsis"
                                                                                       Foreground="{Binding Foreground, RelativeSource={RelativeSource AncestorType=Button}}" />
                                                                        </Button>
                                                                        <TextBlock Text="{Binding DetailLine}" Foreground="#5F6B67" FontSize="12" Margin="0,2,0,0" TextTrimming="CharacterEllipsis" />
                                                                    </StackPanel>
                                                                </Grid>

                                                                <StackPanel Grid.Column="1" Margin="0,0,18,0" VerticalAlignment="Center">
                                                                    <TextBlock Text="{Binding QuantityLine}" Foreground="#5F6B67" FontSize="12" TextTrimming="CharacterEllipsis" />
                                                                    <TextBlock Text="{Binding SummaryLine}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,2,0,0" TextWrapping="NoWrap" />
                                                                </StackPanel>

                                                                <Grid Grid.Column="2" VerticalAlignment="Center">
                                                                    <Grid.ColumnDefinitions>
                                                                        <ColumnDefinition Width="*" />
                                                                        <ColumnDefinition Width="68" />
                                                                    </Grid.ColumnDefinitions>
                                                                    <Grid Margin="0,0,10,0">
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                        </Grid.RowDefinitions>
                                                                        <TextBlock Text="{Binding SubtotalBaseLabel}"
                                                                                   FontSize="15"
                                                                                   FontWeight="Bold"
                                                                                   Foreground="{StaticResource AccentBrush}"
                                                                                   TextAlignment="Right"
                                                                                   TextTrimming="CharacterEllipsis" />
                                                                        <TextBlock Grid.Row="1"
                                                                                   Text="{Binding PaymentStatusLabel}"
                                                                                   FontSize="12"
                                                                                   TextAlignment="Right"
                                                                                   HorizontalAlignment="Right"
                                                                                   Margin="0,2,0,0"
                                                                                   TextTrimming="CharacterEllipsis">
                                                                            <TextBlock.Style>
                                                                                <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                                    <Setter Property="Foreground" Value="#B42318" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsPaymentSettled}" Value="True">
                                                                                            <Setter Property="Foreground" Value="#15803D" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </TextBlock.Style>
                                                                        </TextBlock>
                                                                    </Grid>

                                                                    <Grid Grid.Column="1" HorizontalAlignment="Right" VerticalAlignment="Center">
                                                                        <StackPanel x:Name="ExpenseReadActions" Orientation="Horizontal">
                                                                            <Button Style="{StaticResource CardActionButton}"
                                                                                    Margin="0,0,6,0"
                                                                                    ToolTip="Editar gasto"
                                                                                    Click="EditExpense_Click">
                                                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="9.5" Opacity="0.72" />
                                                                            </Button>
                                                                            <Button Style="{StaticResource CardActionButton}"
                                                                                    ToolTip="Excluir gasto"
                                                                                    Click="DeleteExpense_Click">
                                                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="9.5" Opacity="0.72" />
                                                                            </Button>
                                                                        </StackPanel>
                                                                        <StackPanel x:Name="ExpenseEditActions" Orientation="Horizontal" Visibility="Collapsed">
                                                                            <Button Style="{StaticResource CardAcceptButton}"
                                                                                    Margin="0,0,6,0"
                                                                                    ToolTip="Aceitar alterações"
                                                                                    Click="CompleteExpenseEdit_Click">
                                                                                <TextBlock Text="✓" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                                                                            </Button>
                                                                            <Button Style="{StaticResource CardActionButton}"
                                                                                    ToolTip="Rejeitar alterações"
                                                                                    Click="RejectExpenseEdit_Click">
                                                                                <TextBlock Text="×" FontSize="20" FontWeight="SemiBold" Margin="0,-2,0,0" />
                                                                            </Button>
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Grid>

                                                                <Border Grid.Row="1"
                                                                        Grid.ColumnSpan="3"
                                                                        Background="#FFFFFF"
                                                                        BorderBrush="#B9DED8"
                                                                        BorderThickness="1"
                                                                        CornerRadius="7"
                                                                        Padding="10"
                                                                        Margin="0,10,0,0"
                                                                        PreviewKeyDown="ExpenseEditView_PreviewKeyDown">
                                                                    <Border.Style>
                                                                        <Style TargetType="Border">
                                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Border.Style>
                                                                    <Grid>
                                                                        <Grid.RowDefinitions>
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                            <RowDefinition Height="Auto" />
                                                                        </Grid.RowDefinitions>
                                                                        <Grid.ColumnDefinitions>
                                                                            <ColumnDefinition Width="1.45*" />
                                                                            <ColumnDefinition Width="1*" />
                                                                            <ColumnDefinition Width="1*" />
                                                                            <ColumnDefinition Width="0.72*" />
                                                                            <ColumnDefinition Width="0.72*" />
                                                                        </Grid.ColumnDefinitions>

                                                                        <StackPanel Grid.ColumnSpan="2" Margin="0,0,10,10">
                                                                            <TextBlock Text="Descrição" Style="{StaticResource Caption}" />
                                                                            <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,4,0,0" />
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="2" Margin="0,0,10,10">
                                                                            <TextBlock Text="Categoria" Style="{StaticResource Caption}" />
                                                                            <TextBox Text="{Binding Type, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,4,0,0" />
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Column="3" Grid.ColumnSpan="2" Margin="0,0,0,10">
                                                                            <TextBlock Text="Empresa" Style="{StaticResource Caption}" />
                                                                            <TextBox Text="{Binding Company, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,4,0,0" />
                                                                        </StackPanel>

                                                                        <StackPanel Grid.Row="1" Margin="0,0,10,10">
                                                                            <TextBlock Text="Preço" Style="{StaticResource Caption}" />
                                                                            <TextBox Text="{Binding PriceText, UpdateSourceTrigger=LostFocus}" Padding="6" Margin="0,4,0,0" />
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Row="1" Grid.Column="1" Margin="0,0,10,10">
                                                                            <TextBlock Text="Taxas" Style="{StaticResource Caption}" />
                                                                            <TextBox Text="{Binding TaxesText, UpdateSourceTrigger=LostFocus}" Padding="6" Margin="0,4,0,0" />
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Row="1" Grid.Column="2" Margin="0,0,10,10">
                                                                            <TextBlock Text="Pessoas" Style="{StaticResource Caption}" />
                                                                            <TextBox Text="{Binding People, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,4,0,0" />
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Row="1" Grid.Column="3" Margin="0,0,10,10">
                                                                            <TextBlock Text="Qtd." Style="{StaticResource Caption}" />
                                                                            <TextBox Text="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,4,0,0" />
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Row="1" Grid.Column="4" Margin="0,0,0,10">
                                                                            <TextBlock Text="Moeda" Style="{StaticResource Caption}" />
                                                                            <TextBox Text="{Binding Currency, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,4,0,0" />
                                                                        </StackPanel>

                                                                        <StackPanel Grid.Row="2" Grid.Column="0" Margin="0,0,10,0">
                                                                            <DockPanel LastChildFill="False">
                                                                                <TextBlock Text="Cotação" Style="{StaticResource Caption}" DockPanel.Dock="Left" />
                                                                                <CheckBox Content="Automática"
                                                                                          IsChecked="{Binding UseAutomaticRate}"
                                                                                          DockPanel.Dock="Right"
                                                                                          VerticalAlignment="Center"
                                                                                          FontSize="11" />
                                                                            </DockPanel>
                                                                            <TextBox Text="{Binding ExchangeRateText, UpdateSourceTrigger=LostFocus}"
                                                                                     IsEnabled="{Binding UseFixedRate}"
                                                                                     Padding="6" Margin="0,4,0,0">
                                                                                <TextBox.Style>
                                                                                    <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding UseAutomaticRate}" Value="True">
                                                                                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBox.Style>
                                                                            </TextBox>
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Row="2" Grid.Column="1" Margin="0,0,10,0">
                                                                            <TextBlock Text="{Binding DataContext.BaseCurrencyCode, RelativeSource={RelativeSource AncestorType=Window}, StringFormat='Pago em {0}'}" Style="{StaticResource Caption}" />
                                                                            <TextBox Text="{Binding PaidAmountText, UpdateSourceTrigger=LostFocus}" Padding="6" Margin="0,4,0,0" />
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Row="2" Grid.Column="2" Grid.ColumnSpan="3" Margin="0,0,0,0">
                                                                            <TextBlock Text="Link" Style="{StaticResource Caption}" />
                                                                            <TextBox Text="{Binding Link, UpdateSourceTrigger=PropertyChanged}" Padding="6" Margin="0,4,0,0" />
                                                                        </StackPanel>
                                                                        <StackPanel Grid.Row="3" Grid.ColumnSpan="5" Margin="0,10,0,0">
                                                                            <TextBlock Text="Observações" Style="{StaticResource Caption}" />
                                                                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                                                     Padding="6"
                                                                                     MinHeight="52"
                                                                                     TextWrapping="Wrap"
                                                                                     AcceptsReturn="True"
                                                                                     Margin="0,4,0,0" />
                                                                        </StackPanel>
                                                                    </Grid>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                        <DataTemplate.Triggers>
                                                            <DataTrigger Binding="{Binding IsSelectedForEdit}" Value="True">
                                                                <Setter TargetName="ExpenseSelectionRail" Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                <Setter TargetName="ExpenseReadActions" Property="Visibility" Value="Collapsed" />
                                                                <Setter TargetName="ExpenseEditActions" Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                            <DataTrigger Binding="{Binding HasLink}" Value="True">
                                                                <Setter TargetName="ExpenseTitleText" Property="Visibility" Value="Collapsed" />
                                                                <Setter TargetName="ExpenseTitleLink" Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </DataTemplate.Triggers>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                        </StackPanel>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>
                            </TabItem>

                            <TabItem Header="Resumo">
                                <Grid Margin="0,14,0,0">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                    </Grid.RowDefinitions>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.05*" />
                                        <ColumnDefinition Width="0.95*" />
                                    </Grid.ColumnDefinitions>

                                    <UniformGrid Grid.ColumnSpan="2" Columns="3" Margin="0,0,0,18" MinWidth="520">
                                        <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="7" Padding="16,14" Margin="0,0,10,0">
                                            <StackPanel>
                                                <TextBlock Text="Total" Style="{StaticResource Caption}" />
                                                <TextBlock Text="{Binding EstimatedTotal}" FontSize="22" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#F1F8EF" CornerRadius="7" Padding="16,14" Margin="0,0,10,0">
                                            <StackPanel>
                                                <TextBlock Text="Pago" Style="{StaticResource Caption}" />
                                                <TextBlock Text="{Binding PaidTotal}" FontSize="20" FontWeight="SemiBold" Foreground="#15803D" />
                                            </StackPanel>
                                        </Border>
                                        <Border Background="#FFF4ED" CornerRadius="7" Padding="16,14">
                                            <StackPanel>
                                                <TextBlock Text="A pagar" Style="{StaticResource Caption}" />
                                                <TextBlock Text="{Binding PendingTotal}" FontSize="20" FontWeight="SemiBold" Foreground="#B42318" />
                                            </StackPanel>
                                        </Border>
                                    </UniformGrid>

                                    <Border Grid.Row="1" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1" CornerRadius="7" Padding="18" Margin="0,0,18,0">
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="*" />
                                            </Grid.RowDefinitions>
                                            <TextBlock Text="Categorias" FontSize="16" FontWeight="SemiBold" />
                                            <ItemsControl Grid.Row="1" ItemsSource="{Binding BudgetCategories}" Margin="0,10,0,4">
                                                <ItemsControl.ItemTemplate>
                                                    <DataTemplate>
                                                        <StackPanel Orientation="Horizontal" Margin="0,0,0,5">
                                                            <Border Width="9" Height="9" CornerRadius="4.5" Background="{Binding Color}" VerticalAlignment="Center" Margin="0,1,8,0" />
                                                            <TextBlock FontSize="12" VerticalAlignment="Center">
                                                                <Run Text="{Binding Name}" FontWeight="SemiBold" />
                                                                <Run Text=": " />
                                                                <Run Text="{Binding TotalLabel}" />
                                                                <Run Text=" (" />
                                                                <Run Text="{Binding ShareLabel}" />
                                                                <Run Text=")" />
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </DataTemplate>
                                                </ItemsControl.ItemTemplate>
                                            </ItemsControl>
                                            <local:BudgetPieChart Grid.Row="2"
                                                                  ItemsSource="{Binding BudgetCategories}"
                                                                  Width="230"
                                                                  Height="230"
                                                                  HorizontalAlignment="Center"
                                                                  VerticalAlignment="Center"
                                                                  Margin="0,8,0,0" />
                                        </Grid>
                                    </Border>
                                </Grid>
                            </TabItem>

                            <TabItem Header="Moedas">
                                <Grid Margin="0,14,0,0" MaxWidth="920" HorizontalAlignment="Left">
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="*" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>

                                    <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,0,0,10">
                                        <Run Text="Moeda de referência da viagem: " />
                                        <Run Text="{Binding BaseCurrencyCode, Mode=OneWay}" FontWeight="SemiBold" />
                                    </TextBlock>

                                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                                        <ItemsControl ItemsSource="{Binding CurrencyRates}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate>
                                                    <Border Background="{StaticResource PanelBackground}"
                                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                                            BorderThickness="1"
                                                            CornerRadius="7"
                                                            Padding="10"
                                                            Margin="0,0,0,7">
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="290" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="132" />
                                                                <ColumnDefinition Width="34" />
                                                                <ColumnDefinition Width="34" />
                                                            </Grid.ColumnDefinitions>

                                                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="5" Padding="8,4" Margin="0,0,10,0" Width="52">
                                                                    <TextBlock Text="{Binding Currency}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="13" TextAlignment="Center" />
                                                                </Border>
                                                                <TextBox Text="{Binding Name, UpdateSourceTrigger=PropertyChanged}"
                                                                         FontWeight="SemiBold"
                                                                         FontSize="13"
                                                                         Padding="5,2"
                                                                         Width="140"
                                                                         ToolTip="Nome da moeda" />
                                                                <TextBox Text="{Binding Symbol, UpdateSourceTrigger=PropertyChanged}"
                                                                         Width="54"
                                                                         Padding="5,2"
                                                                         FontSize="12"
                                                                         Margin="8,0,0,0"
                                                                         ToolTip="Símbolo da moeda" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="24,0,0,0">
                                                                <TextBlock Text="1" VerticalAlignment="Center" Margin="0,0,4,0" />
                                                                <TextBlock Text="{Binding Currency}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0" />
                                                                <TextBlock Text="=" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                                <TextBlock Text="{Binding DataContext.BaseCurrencySymbol, RelativeSource={RelativeSource AncestorType=Window}, Mode=OneWay}" VerticalAlignment="Center" FontWeight="SemiBold" Margin="0,0,6,0" />
                                                                <TextBox x:Name="CurrencyRateInput"
                                                                         Text="{Binding RateText, UpdateSourceTrigger=LostFocus}"
                                                                         Width="118"
                                                                         Padding="6"
                                                                         VerticalContentAlignment="Center" />
                                                                <TextBlock x:Name="CurrencyRateFixedLabel"
                                                                           Text="{Binding RateLabel}"
                                                                           Width="118"
                                                                           Padding="6"
                                                                           FontWeight="SemiBold"
                                                                           VerticalAlignment="Center"
                                                                           Visibility="Collapsed" />
                                                            </StackPanel>

                                                            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,0">
                                                                <TextBlock Text="casas dec."
                                                                           Foreground="{StaticResource MutedTextBrush}"
                                                                           FontSize="11"
                                                                           VerticalAlignment="Center"
                                                                           Margin="0,0,6,0" />
                                                                <TextBox Text="{Binding DecimalDigits, UpdateSourceTrigger=PropertyChanged}"
                                                                         Width="42"
                                                                         Padding="4,6"
                                                                         ToolTip="Casas decimais"
                                                                         VerticalContentAlignment="Center"
                                                                         HorizontalContentAlignment="Center" />
                                                            </StackPanel>

                                                            <TextBlock x:Name="CurrencyUpdatedAtLabel"
                                                                       Grid.Column="3"
                                                                       Text="{Binding UpdatedAtLabel}"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="12"
                                                                       TextAlignment="Right"
                                                                       VerticalAlignment="Center"
                                                                       Margin="16,0,0,0" />
                                                            <Button x:Name="UpdateSingleExchangeRateButton"
                                                                    Grid.Column="4"
                                                                    Style="{StaticResource CardActionButton}"
                                                                    ToolTip="Atualizar cotação"
                                                                    Click="UpdateSingleExchangeRate_Click"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="&#xE895;" FontFamily="Segoe MDL2 Assets" FontSize="10.5" Opacity="0.72" />
                                                            </Button>
                                                            <Button x:Name="DeleteCurrencyRateButton"
                                                                    Grid.Column="5"
                                                                    Style="{StaticResource CardActionButton}"
                                                                    ToolTip="Excluir moeda"
                                                                    Click="DeleteCurrencyRate_Click"
                                                                    HorizontalAlignment="Right"
                                                                    VerticalAlignment="Center">
                                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="9.5" Opacity="0.72" />
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                    <DataTemplate.Triggers>
                                                        <DataTrigger Binding="{Binding IsBaseCurrency}" Value="True">
                                                            <Setter TargetName="CurrencyRateInput" Property="Visibility" Value="Collapsed" />
                                                            <Setter TargetName="CurrencyRateFixedLabel" Property="Visibility" Value="Visible" />
                                                            <Setter TargetName="CurrencyUpdatedAtLabel" Property="Visibility" Value="Collapsed" />
                                                            <Setter TargetName="UpdateSingleExchangeRateButton" Property="Visibility" Value="Collapsed" />
                                                            <Setter TargetName="DeleteCurrencyRateButton" Property="Visibility" Value="Collapsed" />
                                                        </DataTrigger>
                                                    </DataTemplate.Triggers>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </ScrollViewer>

                                    <Grid Grid.Row="2" Margin="0,8,0,0">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="Auto" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <TextBox x:Name="NewCurrencyCodeBox"
                                                 Width="92"
                                                 Padding="8"
                                                 CharacterCasing="Upper"
                                                 MaxLength="3"
                                                 ToolTip="Código ISO da moeda, por exemplo USD, CLP ou EUR" />
                                        <Button Grid.Column="1"
                                                Content="+  Adicionar moeda"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="AddCurrencyRate_Click"
                                                Margin="8,0,0,0" />
                                        <Button Grid.Column="2"
                                                Content="Atualizar Cotações"
                                                Style="{StaticResource SecondaryButton}"
                                                Click="UpdateExchangeRates_Click"
                                                Margin="8,0,0,0" />
                                        <TextBlock x:Name="AddCurrencyErrorText"
                                                   Grid.Column="3"
                                                   Foreground="#B42318"
                                                   FontSize="12"
                                                   VerticalAlignment="Center"
                                                   Margin="12,0,0,0"
                                                   Visibility="Collapsed" />
                                    </Grid>
                                </Grid>
                            </TabItem>
                        </TabControl>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                            <Button Content="Salvar Gastos" Style="{StaticResource PrimaryButton}" Click="SaveExpenses_Click" />
                        </StackPanel>
                    </Grid>
            </Grid>

            <Grid x:Name="TasksPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18">
                <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,14">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE73A;" Style="{StaticResource PanelTitleIcon}" />
                                        <TextBlock Text="Tarefas" Style="{StaticResource PanelTitleText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Planeje compras, reservas e pendências da viagem." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,12" />
                                <StackPanel Orientation="Horizontal">
                                    <Button Content="Todas" Style="{StaticResource SecondaryButton}" Click="ShowAllTasks_Click" Margin="0,0,8,0" />
                                    <Button Content="Pendentes" Style="{StaticResource SecondaryButton}" Click="ShowPendingTasks_Click" Margin="0,0,8,0" />
                                    <Button Content="Concluídas" Style="{StaticResource SecondaryButton}" Click="ShowDoneTasks_Click" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Button Content="+  Nova Tarefa" Style="{StaticResource SecondaryButton}" Height="34" Click="AddTask_Click" />
                                <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" Margin="10,0,0,0" ToolTip="Voltar para visão geral" />
                            </StackPanel>
                        </Grid>

                        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="0,4,0,0">
                            <ItemsControl x:Name="TasksList"
                                          ItemsSource="{Binding Tasks}"
                                          AllowDrop="True"
                                          PreviewMouseLeftButtonDown="TasksList_PreviewMouseLeftButtonDown"
                                          PreviewMouseMove="TasksList_PreviewMouseMove"
                                          DragOver="TasksList_DragOver"
                                          Drop="TasksList_Drop">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border BorderBrush="{StaticResource BorderBrushSoft}"
                                                BorderThickness="1"
                                                CornerRadius="7"
                                                Padding="10"
                                                Margin="0,0,0,7"
                                                MouseLeftButtonDown="SelectTaskCard_MouseLeftButtonDown">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource PanelBackground}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelectedForEdit}" Value="True">
                                                            <Setter Property="Background" Value="#F5FCFA" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Grid.RowDefinitions>
                                                    <RowDefinition Height="Auto" />
                                                    <RowDefinition Height="Auto" />
                                                </Grid.RowDefinitions>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="Auto" />
                                                </Grid.ColumnDefinitions>

                                                <Border x:Name="TaskSelectionRail"
                                                        Grid.RowSpan="2"
                                                        Grid.ColumnSpan="3"
                                                        Width="4"
                                                        Margin="-10,-10,0,-10"
                                                        HorizontalAlignment="Left"
                                                        Background="{StaticResource AccentBrush}"
                                                        CornerRadius="7,0,0,7"
                                                        Visibility="Collapsed" />

                                                <CheckBox IsChecked="{Binding IsDone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          VerticalAlignment="Center"
                                                          Margin="6,0,12,0" />

                                                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Title}" FontWeight="SemiBold" FontSize="14" TextWrapping="Wrap">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                        <Setter Property="Foreground" Value="#8B928F" />
                                                                        <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>
                                                    <TextBlock x:Name="TaskNotesPreview"
                                                               Text="{Binding Notes}"
                                                               Foreground="{StaticResource MutedTextBrush}"
                                                               FontSize="12"
                                                               Margin="0,2,0,0"
                                                               TextWrapping="Wrap" />
                                                </StackPanel>

                                                <Grid Grid.Column="2" VerticalAlignment="Center" Margin="10,0,0,0">
                                                    <StackPanel x:Name="TaskReadActions" Orientation="Horizontal">
                                                        <Button Style="{StaticResource CardActionButton}"
                                                                Margin="0,0,6,0"
                                                                ToolTip="Editar tarefa"
                                                                Click="EditTask_Click">
                                                            <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="9.5" Opacity="0.72" />
                                                        </Button>
                                                        <Button Style="{StaticResource CardActionButton}"
                                                                ToolTip="Excluir tarefa"
                                                                Click="DeleteTask_Click">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="9.5" Opacity="0.72" />
                                                        </Button>
                                                    </StackPanel>
                                                    <StackPanel x:Name="TaskEditActions" Orientation="Horizontal" Visibility="Collapsed">
                                                        <Button Style="{StaticResource CardAcceptButton}"
                                                                Margin="0,0,6,0"
                                                                ToolTip="Aceitar alterações"
                                                                Click="CompleteTaskEdit_Click">
                                                            <TextBlock Text="✓" Foreground="White" FontSize="14" FontWeight="SemiBold" />
                                                        </Button>
                                                        <Button Style="{StaticResource CardActionButton}"
                                                                ToolTip="Rejeitar alterações"
                                                                Click="RejectTaskEdit_Click">
                                                            <TextBlock Text="×" FontSize="20" FontWeight="SemiBold" Margin="0,-2,0,0" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>

                                                <Border Grid.Row="1"
                                                        Grid.ColumnSpan="3"
                                                        Background="#FFFFFF"
                                                        BorderBrush="#B9DED8"
                                                        BorderThickness="1"
                                                        CornerRadius="7"
                                                        Padding="10"
                                                        Margin="0,10,0,0"
                                                        PreviewKeyDown="TaskEditView_PreviewKeyDown">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <StackPanel>
                                                        <StackPanel Margin="0,0,0,10">
                                                            <TextBlock Text="Título" Style="{StaticResource Caption}" />
                                                            <TextBox x:Name="TaskTitleEditor"
                                                                     Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                                     FontSize="14"
                                                                     FontWeight="SemiBold"
                                                                     Padding="6"
                                                                     Margin="0,4,0,0" />
                                                        </StackPanel>
                                                        <StackPanel>
                                                            <TextBlock Text="Notas" Style="{StaticResource Caption}" />
                                                            <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}"
                                                                     Padding="6"
                                                                     MinHeight="84"
                                                                     MaxHeight="220"
                                                                     TextWrapping="Wrap"
                                                                     AcceptsReturn="True"
                                                                     VerticalScrollBarVisibility="Auto"
                                                                     Margin="0,4,0,0" />
                                                        </StackPanel>
                                                    </StackPanel>
                                                </Border>
                                            </Grid>
                                        </Border>
                                        <DataTemplate.Triggers>
                                            <DataTrigger Binding="{Binding IsSelectedForEdit}" Value="True">
                                                <Setter TargetName="TaskSelectionRail" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                                <Setter TargetName="TaskReadActions" Property="Visibility" Value="Collapsed" />
                                                <Setter TargetName="TaskEditActions" Property="Visibility" Value="Visible" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding HasNotes}" Value="False">
                                                <Setter TargetName="TaskNotesPreview" Property="Visibility" Value="Collapsed" />
                                            </DataTrigger>
                                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button Content="Salvar Tarefas" Style="{StaticResource PrimaryButton}" Click="SaveTasks_Click" />
                        </StackPanel>
                    </Grid>
            </Grid>

            <Grid x:Name="TipsPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18">
                <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8BD;" Style="{StaticResource PanelTitleIcon}" />
                                        <TextBlock Text="Dicas" Style="{StaticResource PanelTitleText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Guarde links úteis de pesquisa, reservas, blogs e referências da viagem." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Button Content="+  Nova Dica" Style="{StaticResource SecondaryButton}" Height="34" Click="AddTip_Click" />
                                <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" Margin="10,0,0,0" ToolTip="Voltar para visão geral" />
                            </StackPanel>
                        </Grid>

                        <ListBox x:Name="TipsList"
                                 Grid.Row="1"
                                 ItemsSource="{Binding Tips}"
                                 SelectedItem="{Binding SelectedTip}"
                                 PreviewKeyDown="TipsList_PreviewKeyDown"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 AllowDrop="True"
                                 PreviewMouseLeftButtonDown="TipsList_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="TipsList_PreviewMouseMove"
                                 DragOver="TipsList_DragOver"
                                 Drop="TipsList_Drop">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0,0,0,5" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Grid>
                                                    <Border x:Name="ItemChrome"
                                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                                            BorderThickness="1"
                                                            Background="{StaticResource PanelBackground}"
                                                            CornerRadius="8"
                                                            Padding="6">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <Border x:Name="SelectionRail"
                                                            Width="4"
                                                            Margin="0"
                                                            HorizontalAlignment="Left"
                                                            Background="{StaticResource AccentBrush}"
                                                            CornerRadius="8,0,0,8"
                                                            Visibility="Collapsed" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="#F5FCFA" />
                                                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        <Setter TargetName="SelectionRail" Property="Visibility" Value="Visible" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Margin="0,0,10,0">
                                            <Grid x:Name="TipReadView"
                                                  Background="Transparent"
                                                  MouseLeftButtonDown="TipReadView_MouseLeftButtonDown">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="0.22*" />
                                                    <ColumnDefinition Width="0.78*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0" />
                                                <Button x:Name="TipLinkButton"
                                                        Grid.Column="1"
                                                        Style="{StaticResource LinkButton}"
                                                        Click="OpenTipLink_Click"
                                                        ToolTip="Abrir link"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Url}"
                                                               FontSize="12"
                                                                Foreground="{StaticResource AccentBrush}"
                                                                TextTrimming="CharacterEllipsis" />
                                                </Button>
                                                <TextBlock x:Name="TipPlainText"
                                                           Grid.Column="1"
                                                           Text="{Binding Url}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           Visibility="Collapsed" />
                                            </Grid>

                                            <Grid x:Name="TipEditView"
                                                  Visibility="Collapsed"
                                                  LostKeyboardFocus="TipEditView_LostKeyboardFocus"
                                                  PreviewKeyDown="TipEditView_PreviewKeyDown">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="0.22*" />
                                                    <ColumnDefinition Width="0.78*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12"
                                                         FontWeight="SemiBold"
                                                         Padding="5,2"
                                                         Margin="0,0,6,0"
                                                         BorderBrush="{StaticResource BorderBrushSoft}"
                                                         Background="{StaticResource InputBackground}" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12"
                                                         Padding="5,2"
                                                         Foreground="{StaticResource AccentBrush}"
                                                         BorderBrush="{StaticResource BorderBrushSoft}"
                                                         Background="{StaticResource InputBackground}" />
                                            </Grid>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource CardActionButton}"
                                                    Margin="0,0,6,0"
                                                    ToolTip="Editar nome e link"
                                                    Click="EditTipCard_Click">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="9.5" Opacity="0.72" />
                                            </Button>
                                            <Button Style="{StaticResource CardActionButton}"
                                                    ToolTip="Excluir dica"
                                                    Click="DeleteTipCard_Click">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="9.5" Opacity="0.72" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding HasValidUrl}" Value="False">
                                            <Setter TargetName="TipPlainText" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="TipLinkButton" Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter TargetName="TipReadView" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="TipEditView" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button Content="Salvar Dicas" Style="{StaticResource PrimaryButton}" Click="SaveTips_Click" />
                        </StackPanel>
                    </Grid>
            </Grid>

            <Grid x:Name="MapPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18">
                <Grid>
                        <Grid.Resources>
                            <Style TargetType="TextBox" BasedOn="{StaticResource {x:Type TextBox}}">
                                <Setter Property="Background" Value="{StaticResource PanelBackground}" />
                            </Style>
                        </Grid.Resources>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE707;" Style="{StaticResource PanelTitleIcon}" />
                                        <TextBlock Text="Mapa" Style="{StaticResource PanelTitleText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Informe o link público do Google My Maps e visualize o mapa da viagem." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Button Content="Abrir no navegador" Style="{StaticResource SecondaryButton}" Height="34" Click="OpenMyMaps_Click" />
                                <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" Margin="10,0,0,0" ToolTip="Voltar para visão geral" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Margin="0,0,0,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="Link público do Google My Maps" Style="{StaticResource Caption}" />
                                        <TextBox x:Name="MapUrlBox"
                                                 Text="{Binding MyMapsUrl, UpdateSourceTrigger=PropertyChanged}"
                                                 Height="34"
                                                 Margin="0,4,0,0"
                                                 LostKeyboardFocus="MapUrlBox_LostKeyboardFocus"
                                                 KeyDown="MapUrlBox_KeyDown" />
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                                        <Button Content="Salvar URL" Style="{StaticResource PrimaryButton}" Click="SaveMap_Click" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock x:Name="MapUrlError"
                                           Foreground="#D94F4F"
                                           FontSize="12"
                                           Margin="0,5,0,0"
                                           Visibility="Collapsed"
                                           TextWrapping="Wrap" />
                            </StackPanel>

                            <Border Grid.Row="1" Background="#DDE8DF" CornerRadius="8" ClipToBounds="True">
                                <Grid>
                                    <wv2:WebView2 x:Name="MainMapBrowser" />
                                    <TextBlock x:Name="MainMapPlaceholder"
                                               Text="Cole aqui o link público do Google My Maps para exibir o mapa."
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="24" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
            </Grid>

            <Grid x:Name="FilesPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18"
                  AllowDrop="True"
                  DragOver="FilesPanel_DragOver"
                  Drop="FilesPanel_Drop">
                <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8B7;" Style="{StaticResource PanelTitleIcon}" />
                                        <TextBlock Text="Arquivos" Style="{StaticResource PanelTitleText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Anexe arquivos da viagem. Eles serão copiados para a pasta da viagem." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Button Content="+  Anexar arquivos" Style="{StaticResource SecondaryButton}" Height="34" Click="AttachFiles_Click" />
                                <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" Margin="10,0,0,0" ToolTip="Voltar para visão geral" />
                            </StackPanel>
                        </Grid>

                        <ListBox x:Name="AttachmentsList"
                                 Grid.Row="1"
                                 ItemsSource="{Binding Attachments}"
                                 SelectedItem="{Binding SelectedAttachment}"
                                 PreviewKeyDown="AttachmentsGrid_PreviewKeyDown"
                                 PreviewMouseLeftButtonDown="AttachmentsList_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="AttachmentsList_PreviewMouseMove"
                                 MouseDoubleClick="AttachmentsList_MouseDoubleClick"
                                 DragOver="AttachmentsList_DragOver"
                                 Drop="AttachmentsList_Drop"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0,0,0,5" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Grid>
                                                    <Border x:Name="ItemChrome"
                                                            BorderBrush="{StaticResource BorderBrushSoft}"
                                                            BorderThickness="1"
                                                            Background="{StaticResource PanelBackground}"
                                                            CornerRadius="8"
                                                            Padding="9,8">
                                                        <ContentPresenter />
                                                    </Border>
                                                    <Border x:Name="SelectionRail"
                                                            Width="4"
                                                            Margin="0"
                                                            HorizontalAlignment="Left"
                                                            Background="{StaticResource AccentBrush}"
                                                            CornerRadius="8,0,0,8"
                                                            Visibility="Collapsed" />
                                                </Grid>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="#F5FCFA" />
                                                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        <Setter TargetName="SelectionRail" Property="Visibility" Value="Visible" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="42">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="46" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34" Height="36" CornerRadius="5" Background="#F7F9F8" HorizontalAlignment="Left">
                                            <Image Width="28" Height="28" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Image.Source>
                                                    <MultiBinding Converter="{StaticResource AttachmentIconConverter}">
                                                        <Binding Path="File" />
                                                        <Binding Path="DataContext.TripPath" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </Image.Source>
                                            </Image>
                                        </Border>
                                        <Grid Grid.Column="1" Margin="0,0,14,0" VerticalAlignment="Center">
                                            <StackPanel x:Name="AttachmentReadStack" VerticalAlignment="Center">
                                                <TextBlock x:Name="AttachmentReadView"
                                                           Text="{Binding File}"
                                                           FontSize="14"
                                                           FontWeight="SemiBold"
                                                           Foreground="{StaticResource TextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           ToolTip="Duplo-clique para abrir" />
                                                <TextBlock x:Name="AttachmentMetadataView"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12"
                                                           Margin="0,1,0,0">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource AttachmentMetadataConverter}">
                                                            <Binding Path="File" />
                                                            <Binding Path="DataContext.TripPath" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBox x:Name="AttachmentEditView"
                                                     Text="{Binding File, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="13"
                                                     FontWeight="SemiBold"
                                                     Padding="5,2"
                                                     BorderBrush="{StaticResource BorderBrushSoft}"
                                                     Background="{StaticResource InputBackground}"
                                                     Visibility="Collapsed"
                                                     LostKeyboardFocus="AttachmentEditView_LostKeyboardFocus"
                                                     PreviewKeyDown="AttachmentEditView_PreviewKeyDown" />
                                        </Grid>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Style="{StaticResource CardActionButton}"
                                                    Margin="0,0,6,0"
                                                    ToolTip="Renomear arquivo"
                                                    Click="RenameAttachment_Click">
                                                <TextBlock Text="&#xE70F;" FontFamily="Segoe MDL2 Assets" FontSize="9.5" Opacity="0.72" />
                                            </Button>
                                            <Button Style="{StaticResource CardActionButton}"
                                                    ToolTip="Excluir arquivo"
                                                    Click="DeleteAttachment_Click">
                                                <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="9.5" Opacity="0.72" />
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter TargetName="AttachmentReadStack" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="AttachmentEditView" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button Content="Salvar Arquivos" Style="{StaticResource PrimaryButton}" Click="SaveAttachments_Click" />
                        </StackPanel>
                    </Grid>
            </Grid>

            <!-- ItineraryPanel -->
            <Grid x:Name="ItineraryPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18"
                  Focusable="True"
                  SizeChanged="ItineraryTimeline_SizeChanged"
                  PreviewMouseLeftButtonDown="ItineraryPanel_MouseDown"
                  PreviewKeyDown="ItineraryPanel_PreviewKeyDown"
                  PreviewMouseWheel="ItineraryPanel_PreviewMouseWheel">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <!-- Header -->
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <TextBlock Text="&#xE8FD;" Style="{StaticResource PanelTitleIcon}" />
                        <TextBlock Text="Roteiro" Style="{StaticResource PanelTitleText}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Content="+ Dia" Style="{StaticResource SecondaryButton}" Click="AddItineraryDay_Click" Margin="0,0,8,0" />
                        <Button Content="+ Atividade" Style="{StaticResource SecondaryButton}" Click="AddItineraryActivity_Click" Margin="0,0,10,0" />
                        <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" ToolTip="Voltar para visão geral" />
                    </StackPanel>
                </Grid>

                <!-- Version tabs (Row 1) -->
                <Border Grid.Row="1" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Margin="0,0,0,10" Padding="0,0,0,0">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <!-- Scrollable tab list -->
                        <ScrollViewer HorizontalScrollBarVisibility="Auto" VerticalScrollBarVisibility="Disabled">
                            <ItemsControl ItemsSource="{Binding VersionTabs}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Bottom" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Margin="0,4,4,0" Padding="10,5" CornerRadius="4,4,0,0" Cursor="Hand"
                                                MouseLeftButtonDown="VersionTab_MouseDown">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource SidebarPanelBackground}" />
                                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                    <Setter Property="BorderThickness" Value="1,1,1,0" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource PanelBackground}" />
                                                            <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel Orientation="Horizontal">
                                                <!-- Name (display mode) -->
                                                <TextBlock VerticalAlignment="Center" FontSize="12" Text="{Binding Name}">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock">
                                                            <Setter Property="FontWeight" Value="Normal" />
                                                            <Setter Property="Visibility" Value="Visible" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                    <Setter Property="FontWeight" Value="SemiBold" />
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                                <!-- Rename input -->
                                                <TextBox FontSize="12" Width="110" Height="24" VerticalAlignment="Center"
                                                         Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                                         PreviewKeyDown="VersionTabRename_PreviewKeyDown"
                                                         LostFocus="VersionTabRename_LostFocus"
                                                         IsVisibleChanged="VersionTabRenameBox_IsVisibleChanged">
                                                    <TextBox.Style>
                                                        <Style TargetType="TextBox">
                                                            <Setter Property="Visibility" Value="Collapsed" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBox.Style>
                                                </TextBox>
                                                <!-- Delete button -->
                                                <Button Style="{StaticResource CardActionButton}" ToolTip="Excluir versão"
                                                        Click="DeleteVersion_Click" Margin="4,0,0,0">
                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="9" Opacity="0.6" />
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </ScrollViewer>
                        <!-- New / Duplicate / Shift-date buttons -->
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="8,0,0,4">
                            <Button Content="+ Nova versão" Style="{StaticResource SecondaryButton}" Click="AddVersion_Click" Margin="0,0,6,0" />
                            <Button Content="⧉ Duplicar" Style="{StaticResource SecondaryButton}" Click="DuplicateVersion_Click" Margin="0,0,6,0" />
                            <Button x:Name="ShiftDateButton" Content="📅 Alterar data" Style="{StaticResource SecondaryButton}" Click="ShiftDate_Click" />
                            <Popup x:Name="ShiftDatePopup"
                                   PlacementTarget="{Binding ElementName=ShiftDateButton}"
                                   Placement="Bottom" StaysOpen="False" AllowsTransparency="True">
                                <Border Background="{StaticResource PanelBackground}"
                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                        BorderThickness="1" CornerRadius="6" Padding="8">
                                    <Border.Effect>
                                        <DropShadowEffect Color="#000000" Opacity="0.15" BlurRadius="12" ShadowDepth="4" Direction="270" />
                                    </Border.Effect>
                                    <StackPanel>
                                        <TextBlock Text="Data do primeiro dia do roteiro"
                                                   FontSize="11" Opacity="0.6" Margin="2,0,2,6" />
                                        <Calendar x:Name="ShiftDateCalendar"
                                                  SelectionMode="SingleDate"
                                                  SelectedDatesChanged="ShiftDateCalendar_SelectedDatesChanged" />
                                    </StackPanel>
                                </Border>
                            </Popup>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Timeline -->
                <ScrollViewer x:Name="ItineraryScrollViewer" Grid.Row="2" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel>


                        <!-- Days -->
                        <ItemsControl x:Name="ItineraryDaysList" ItemsSource="{Binding Itinerary}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Margin="0,0,0,6" CornerRadius="8">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Background" Value="{StaticResource PanelBackground}" />
                                                <Setter Property="Opacity" Value="1" />
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                                <Setter Property="BorderThickness" Value="1" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsDragTarget}" Value="True">
                                                        <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsInEditMode}" Value="True">
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                        <Setter Property="BorderThickness" Value="2" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDimmed}" Value="True">
                                                        <Setter Property="Opacity" Value="0.35" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                                        <Setter Property="Opacity" Value="0.55" />
                                                        <Setter Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                                <RowDefinition Height="Auto" />
                                            </Grid.RowDefinitions>

                                            <!-- Day strip row -->
                                            <Grid Grid.Row="0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="112" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>

                                            <!-- Day label (duplo-clique para editar; handle ⠿ para arrastar) -->
                                            <Border x:Name="DayLabelBorder" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,1,0"
                                                    Padding="4,8,12,8" Background="Transparent"
                                                    MouseLeftButtonDown="DayLabel_MouseDown" Cursor="Arrow">
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="18" />
                                                        <ColumnDefinition Width="*" />
                                                    </Grid.ColumnDefinitions>

                                                    <!-- Drag handle -->
                                                    <TextBlock Grid.Column="0" Text="⠿" FontSize="13"
                                                               VerticalAlignment="Center" HorizontalAlignment="Center"
                                                               Cursor="SizeNS"
                                                               PreviewMouseLeftButtonDown="DayHandle_MouseDown"
                                                               PreviewMouseMove="DayHandle_MouseMove"
                                                               PreviewMouseLeftButtonUp="DayHandle_MouseUp">
                                                        <TextBlock.Style>
                                                            <Style TargetType="TextBlock">
                                                                <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                                                <Setter Property="Opacity" Value="0" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsMouseOver, RelativeSource={RelativeSource AncestorType=Border}}" Value="True">
                                                                        <Setter Property="Opacity" Value="0.5" />
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding IsDragging}" Value="True">
                                                                        <Setter Property="Opacity" Value="0.8" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </TextBlock.Style>
                                                    </TextBlock>

                                                    <!-- Day info -->
                                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                        <TextBlock Text="{Binding DateLabel}" FontSize="11" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentBrush}" />
                                                        <TextBlock Text="{Binding Title}" FontSize="14" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"
                                                                   Margin="0,2,0,0" />
                                                        <TextBlock Text="{Binding Summary}" FontSize="11" TextWrapping="Wrap"
                                                                   Foreground="{StaticResource MutedTextBrush}" Margin="0,3,0,0">
                                                            <TextBlock.Style>
                                                                <Style TargetType="TextBlock">
                                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                                    <Style.Triggers>
                                                                        <DataTrigger Binding="{Binding HasSummary}" Value="True">
                                                                            <Setter Property="Visibility" Value="Visible" />
                                                                        </DataTrigger>
                                                                    </Style.Triggers>
                                                                </Style>
                                                            </TextBlock.Style>
                                                        </TextBlock>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>

                                            <!-- Canvas area -->
                                            <ScrollViewer Grid.Column="1" HorizontalScrollBarVisibility="Disabled"
                                                          VerticalScrollBarVisibility="Disabled"
                                                          ClipToBounds="True"
                                                          Margin="6,0">
                                                <Canvas Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}"
                                                        Background="Transparent"
                                                        MouseLeftButtonDown="DayCanvas_MouseLeftButtonDown">
                                                    <!-- Slot selecionado (indicador de colar bloco) -->
                                                    <Rectangle Canvas.Top="{Binding SelectionRectTop}"
                                                               Canvas.Left="{Binding SelectedSlotX}"
                                                               Width="{Binding SlotWidth}"
                                                               Height="{Binding SelectionRectHeight}"
                                                               Fill="Transparent"
                                                               Stroke="{StaticResource AccentBrush}"
                                                               StrokeThickness="1.5"
                                                               StrokeDashArray="5 3"
                                                               Opacity="0.35"
                                                               IsHitTestVisible="False"
                                                               Visibility="{Binding HasSelectedSlot, Converter={StaticResource BoolToVisibility}}" />
                                                    <!-- Grid lines -->
                                                    <ItemsControl ItemsSource="{Binding SlotLinePositions}"
                                                                  Canvas.Left="0" Canvas.Top="0"
                                                                  Visibility="{Binding DataContext.ShowItineraryGrid, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemContainerStyle>
                                                            <Style TargetType="ContentPresenter">
                                                                <Setter Property="Canvas.Left" Value="{Binding}" />
                                                                <Setter Property="Canvas.Top" Value="0" />
                                                            </Style>
                                                        </ItemsControl.ItemContainerStyle>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Line X1="0" Y1="0" X2="0"
                                                                      Y2="{Binding DataContext.CanvasHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                                      Stroke="#44000000" StrokeThickness="1" StrokeDashArray="3,4" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <!-- Activities -->
                                                    <ItemsControl ItemsSource="{Binding Activities}"
                                                                  Canvas.Left="0" Canvas.Top="0"
                                                                  Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}">
                                                        <ItemsControl.ItemsPanel>
                                                            <ItemsPanelTemplate>
                                                                <Canvas />
                                                            </ItemsPanelTemplate>
                                                        </ItemsControl.ItemsPanel>
                                                        <ItemsControl.ItemContainerStyle>
                                                            <Style TargetType="ContentPresenter">
                                                                <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}" />
                                                                <Setter Property="Canvas.Top" Value="4" />
                                                            </Style>
                                                        </ItemsControl.ItemContainerStyle>
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <Grid Width="{Binding BlockWidth}" Height="{Binding BlockHeight}"
                                                                      MouseLeftButtonDown="ActivityBlock_MouseDown"
                                                                      MouseMove="ActivityBlock_MouseMove"
                                                                      MouseLeftButtonUp="ActivityBlock_MouseUp">
                                                                    <Grid.Style>
                                                                        <Style TargetType="Grid">
                                                                            <Setter Property="Opacity" Value="1" />
                                                                            <Style.Triggers>
                                                                                <DataTrigger Binding="{Binding IsRefeicao}" Value="True">
                                                                                    <Setter Property="Opacity" Value="0.65" />
                                                                                </DataTrigger>
                                                                                <DataTrigger Binding="{Binding IsDimmed}" Value="True">
                                                                                    <Setter Property="Opacity" Value="0.25" />
                                                                                </DataTrigger>
                                                                            </Style.Triggers>
                                                                        </Style>
                                                                    </Grid.Style>
                                                                    <Border>
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="CornerRadius" Value="5" />
                                                                                <Setter Property="VerticalAlignment" Value="Stretch" />
                                                                                <Setter Property="Background" Value="{Binding DisplayColor, Converter={StaticResource StringToBrush}}" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsPernoite}" Value="True">
                                                                                        <Setter Property="CornerRadius" Value="20" />
                                                                                        <Setter Property="VerticalAlignment" Value="Center" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                        <StackPanel VerticalAlignment="Center">
                                                                        <StackPanel.Style>
                                                                            <Style TargetType="StackPanel">
                                                                                <Setter Property="Margin" Value="5,2" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsPernoite}" Value="True">
                                                                                        <Setter Property="Margin" Value="10,5" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </StackPanel.Style>
                                                                            <Grid>
                                                                                <Grid.ColumnDefinitions>
                                                                                    <ColumnDefinition Width="Auto" />
                                                                                    <ColumnDefinition Width="*" />
                                                                                </Grid.ColumnDefinitions>
                                                                                <TextBlock Grid.Column="0"
                                                                                           Text="{Binding DisplayIcon}"
                                                                                           FontFamily="Segoe UI Emoji"
                                                                                           FontSize="{Binding IconFontSize}" Margin="0,0,3,0" VerticalAlignment="Top"
                                                                                           Foreground="{Binding DisplayTextColor, Converter={StaticResource StringToBrush}}" />
                                                                                <TextBlock Grid.Column="1"
                                                                                           Text="{Binding DisplayTitle}"
                                                                                           FontSize="{Binding FontSize}" FontWeight="SemiBold"
                                                                                           Foreground="{Binding DisplayTextColor, Converter={StaticResource StringToBrush}}"
                                                                                           VerticalAlignment="Center"
                                                                                           TextAlignment="Center"
                                                                                           TextWrapping="Wrap" />
                                                                            </Grid>
                                                                            <TextBlock Text="{Binding DisplayDetails}"
                                                                                       FontSize="{Binding DetailsFontSize}" HorizontalAlignment="Center"
                                                                                       TextAlignment="Center" TextWrapping="Wrap"
                                                                                       Foreground="{Binding DisplayTextColor, Converter={StaticResource StringToBrush}}"
                                                                                       Opacity="0.78">
                                                                                <TextBlock.Style>
                                                                                    <Style TargetType="TextBlock">
                                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding DisplayHasDetails}" Value="True">
                                                                                                <Setter Property="Visibility" Value="Visible" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </TextBlock.Style>
                                                                            </TextBlock>
                                                                        </StackPanel>
                                                                    </Border>
                                                                    <!-- Selection / overlap highlight -->
                                                                    <Border CornerRadius="6" BorderThickness="2" Background="Transparent">
                                                                        <Border.Style>
                                                                            <Style TargetType="Border">
                                                                                <Setter Property="BorderBrush" Value="Transparent" />
                                                                                <Style.Triggers>
                                                                                    <DataTrigger Binding="{Binding IsOverlapping}" Value="True">
                                                                                        <Setter Property="BorderBrush" Value="#EF4444" />
                                                                                    </DataTrigger>
                                                                                    <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                        <Setter Property="BorderBrush" Value="#2563EB" />
                                                                                    </DataTrigger>
                                                                                </Style.Triggers>
                                                                            </Style>
                                                                        </Border.Style>
                                                                    </Border>
                                                                </Grid>
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                </Canvas>
                                            </ScrollViewer>

                                            </Grid>

                                            <!-- Inline edit form (Row 1) -->
                                            <Border Grid.Row="1" Tag="ItineraryEditForm" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="14,12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding HasEditingBlock}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <!-- Row 0: Título + Duração + Tipo -->
                                                    <StackPanel Grid.Row="0" Margin="0,0,10,8">
                                                        <TextBlock Text="Título" Style="{StaticResource Caption}" />
                                                        <TextBox Text="{Binding EditingActivity.EditTitle, UpdateSourceTrigger=PropertyChanged}" Height="32" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,8">
                                                        <TextBlock Text="Duração (blocos)" Style="{StaticResource Caption}" />
                                                        <TextBox Text="{Binding EditingActivity.EditDurationSlots, UpdateSourceTrigger=PropertyChanged}" Height="32" Width="110" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,8">
                                                        <TextBlock Text="Tipo" Style="{StaticResource Caption}" />
                                                        <ComboBox ItemsSource="{x:Static local:ItineraryActivityViewModel.TypeOptions}"
                                                                  SelectedItem="{Binding EditingActivity.EditType, UpdateSourceTrigger=PropertyChanged}"
                                                                  Height="32" Width="110"
                                                                  DropDownOpened="EditTypeCombo_DropDownOpened"
                                                                  DropDownClosed="EditTypeCombo_DropDownClosed" />
                                                    </StackPanel>
                                                    <!-- Accept / Reject / Delete (Row 0, Col 3) -->
                                                    <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,8">
                                                        <Button Style="{StaticResource CardActionButton}" ToolTip="Aceitar (Enter)" Click="AcceptEdit_Click" Margin="0,0,2,0">
                                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                                        </Button>
                                                        <Button Style="{StaticResource CardActionButton}" ToolTip="Rejeitar (Esc)" Click="RejectEdit_Click" Margin="0,0,2,0">
                                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                                        </Button>
                                                        <Button Style="{StaticResource CardActionButton}" ToolTip="Excluir atividade" Click="DeleteEditActivity_Click">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Opacity="0.72" />
                                                        </Button>
                                                    </StackPanel>

                                                    <!-- Row 1: Detalhes + Dados adicionais -->
                                                    <StackPanel Grid.Row="1" Margin="0,0,10,8">
                                                        <TextBlock Text="Detalhes" Style="{StaticResource Caption}" />
                                                        <TextBox Text="{Binding EditingActivity.EditDetails, UpdateSourceTrigger=PropertyChanged}"
                                                                 Height="64" TextWrapping="Wrap"
                                                                 VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                                                                 PreviewKeyDown="MultilineEditField_PreviewKeyDown" />
                                                    </StackPanel>
                                                    <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,8">
                                                        <TextBlock Text="Dados adicionais" Style="{StaticResource Caption}" />
                                                        <TextBox Text="{Binding EditingActivity.EditAdditionalData, UpdateSourceTrigger=PropertyChanged}"
                                                                 Height="64" TextWrapping="Wrap"
                                                                 VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                                                                 PreviewKeyDown="MultilineEditField_PreviewKeyDown" />
                                                    </StackPanel>

                                                    <!-- Row 2: Ícone + Cor (esquerda) | Copiar Estilo / Colar Estilo / Duplicar Atividade (direita) -->
                                                    <DockPanel Grid.Row="2" Grid.ColumnSpan="4">
                                                        <Button DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                                                                Style="{StaticResource SecondaryButton}" Click="CopyEditActivity_Click">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                                <TextBlock Text="Duplicar Atividade" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                                                                Style="{StaticResource SecondaryButton}" Click="PasteStyleActivity_Click"
                                                                IsEnabled="{Binding DataContext.HasStyleClipboard, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                ToolTip="Colar estilo copiado (Ctrl+V)">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                                <TextBlock Text="Colar Estilo" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                        <Button DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                                                                Style="{StaticResource SecondaryButton}" Click="CopyStyleActivity_Click"
                                                                ToolTip="Copiar estilo do bloco (Ctrl+C)">
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xEF90;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                                <TextBlock Text="Copiar Estilo" VerticalAlignment="Center" />
                                                            </StackPanel>
                                                        </Button>
                                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                            <TextBlock Text="Ícone" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                            <WrapPanel VerticalAlignment="Center">
                                                                <Button Tag="" Style="{StaticResource IconPickerButton}" ToolTip="Nenhum" Click="EditActivityIcon_Click">
                                                                    <TextBlock Text="✕" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                                </Button>
                                                                <Button Tag="✈" Style="{StaticResource IconPickerButton}" ToolTip="Avião" Click="EditActivityIcon_Click"><TextBlock Text="✈" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="🚗" Style="{StaticResource IconPickerButton}" ToolTip="Carro" Click="EditActivityIcon_Click"><TextBlock Text="🚗" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="🚌" Style="{StaticResource IconPickerButton}" ToolTip="Ônibus" Click="EditActivityIcon_Click"><TextBlock Text="🚌" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="🚢" Style="{StaticResource IconPickerButton}" ToolTip="Barco" Click="EditActivityIcon_Click"><TextBlock Text="🚢" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="🚶" Style="{StaticResource IconPickerButton}" ToolTip="Caminhada" Click="EditActivityIcon_Click"><TextBlock Text="🚶" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="🍴" Style="{StaticResource IconPickerButton}" ToolTip="Restaurante" Click="EditActivityIcon_Click"><TextBlock Text="🍴" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="🛏" Style="{StaticResource IconPickerButton}" ToolTip="Hospedagem" Click="EditActivityIcon_Click"><TextBlock Text="🛏" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="📷" Style="{StaticResource IconPickerButton}" ToolTip="Câmera" Click="EditActivityIcon_Click"><TextBlock Text="📷" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="📍" Style="{StaticResource IconPickerButton}" ToolTip="Ponto no mapa" Click="EditActivityIcon_Click"><TextBlock Text="📍" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="🎫" Style="{StaticResource IconPickerButton}" ToolTip="Ingresso" Click="EditActivityIcon_Click"><TextBlock Text="🎫" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="⛺" Style="{StaticResource IconPickerButton}" ToolTip="Acampamento" Click="EditActivityIcon_Click"><TextBlock Text="⛺" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="🥤" Style="{StaticResource IconPickerButton}" ToolTip="Lanche" Click="EditActivityIcon_Click"><TextBlock Text="🥤" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="🛒" Style="{StaticResource IconPickerButton}" ToolTip="Compras" Click="EditActivityIcon_Click"><TextBlock Text="🛒" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                <Button Tag="💩" Style="{StaticResource IconPickerButton}" ToolTip="Cocô" Click="EditActivityIcon_Click"><TextBlock Text="💩" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                            </WrapPanel>
                                                            <TextBlock Text="Cor" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="16,0,8,0" />
                                                            <Button Width="34" Height="34" MinHeight="34" VerticalAlignment="Center"
                                                                    Background="{Binding EditingActivity.EditColor, Converter={StaticResource StringToBrush}}"
                                                                    BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1"
                                                                    Style="{StaticResource ButtonBase}"
                                                                    Click="EditActivityColor_Click"
                                                                    ToolTip="Escolher cor" />
                                                        </StackPanel>
                                                    </DockPanel>
                                                </Grid>
                                            </Border>
                                            <!-- Day data edit form (Row 2) -->
                                            <Border Grid.Row="2" Tag="ItineraryEditForm" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="14,12">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsEditingDay}" Value="True">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*" />
                                                        <ColumnDefinition Width="Auto" />
                                                    </Grid.ColumnDefinitions>

                                                    <StackPanel Grid.Column="0" Margin="0,0,10,0">
                                                        <TextBlock Text="Resumo" Style="{StaticResource Caption}" />
                                                        <TextBox Text="{Binding EditDaySummary, UpdateSourceTrigger=PropertyChanged}" Height="32" Margin="0,4,0,0" />
                                                    </StackPanel>

                                                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom">
                                                        <Button Style="{StaticResource CardActionButton}" ToolTip="Aceitar (Enter)" Click="AcceptDayEdit_Click" Margin="0,0,2,0">
                                                            <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                                        </Button>
                                                        <Button Style="{StaticResource CardActionButton}" ToolTip="Rejeitar (Esc)" Click="RejectDayEdit_Click" Margin="0,0,2,0">
                                                            <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                                        </Button>
                                                        <Button Style="{StaticResource CardActionButton}" ToolTip="Excluir dia" Click="RemoveItineraryDay_Click">
                                                            <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                                        </Button>
                                                    </StackPanel>
                                                </Grid>
                                            </Border>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <!-- Bank Section -->
                        <Border Margin="0,6,0,0" CornerRadius="8">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{StaticResource PanelBackground}" />
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderBrushSoft}" />
                                    <Setter Property="BorderThickness" Value="1" />
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <!-- Bank header -->
                                <Grid Grid.Row="0" Margin="12,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto" />
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource ButtonBase}" Padding="0" Background="Transparent" BorderThickness="0"
                                            Click="ToggleBank_Click" Cursor="Hand">
                                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                            <TextBlock FontSize="11" VerticalAlignment="Center" Margin="0,0,5,0"
                                                       Foreground="{StaticResource MutedTextBrush}">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Text" Value="▾" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsBankExpanded}" Value="False">
                                                                <Setter Property="Text" Value="▸" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="Banco" FontSize="13" FontWeight="SemiBold" VerticalAlignment="Center" />
                                        </StackPanel>
                                    </Button>
                                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                                        <Button Style="{StaticResource CardActionButton}" ToolTip="Remover linha" Click="RemoveBankRow_Click" Margin="0,0,4,0">
                                            <TextBlock Text="−" FontSize="13" />
                                        </Button>
                                        <Button Style="{StaticResource CardActionButton}" ToolTip="Adicionar linha" Click="AddBankRow_Click" Margin="0,0,8,0">
                                            <TextBlock Text="+" FontSize="13" />
                                        </Button>
                                        <Button Content="+ Atividade" Style="{StaticResource SecondaryButton}" Click="AddBankActivity_Click" />
                                    </StackPanel>
                                </Grid>

                                <!-- Bank body (collapsible) -->
                                <Grid Grid.Row="1">
                                    <Grid.Style>
                                        <Style TargetType="Grid">
                                            <Setter Property="Visibility" Value="Visible" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsBankExpanded}" Value="False">
                                                    <Setter Property="Visibility" Value="Collapsed" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Grid.Style>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="112" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>

                                    <!-- Spacer 112px para alinhar canvas com os dias -->
                                    <Border Grid.Column="0" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,1,0" />

                                    <!-- Bank row canvases -->
                                    <ItemsControl x:Name="BankRowsList" Grid.Column="1" ItemsSource="{Binding BankRows}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Grid>
                                                    <Grid.Style>
                                                        <Style TargetType="Grid">
                                                            <Setter Property="Background" Value="Transparent" />
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDragTarget}" Value="True">
                                                                    <Setter Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Grid.Style>
                                                    <Grid.RowDefinitions>
                                                        <RowDefinition Height="Auto" />
                                                        <RowDefinition Height="Auto" />
                                                    </Grid.RowDefinitions>

                                                    <!-- Canvas -->
                                                    <ScrollViewer Grid.Row="0" HorizontalScrollBarVisibility="Disabled"
                                                                  VerticalScrollBarVisibility="Disabled"
                                                                  ClipToBounds="True" Margin="6,0">
                                                        <Canvas Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}"
                                                                Background="Transparent"
                                                                MouseLeftButtonDown="DayCanvas_MouseLeftButtonDown">
                                                            <!-- Slot selecionado (indicador de colar bloco) -->
                                                            <Rectangle Canvas.Top="{Binding SelectionRectTop}"
                                                                       Canvas.Left="{Binding SelectedSlotX}"
                                                                       Width="{Binding SlotWidth}"
                                                                       Height="{Binding SelectionRectHeight}"
                                                                       Fill="Transparent"
                                                                       Stroke="{StaticResource AccentBrush}"
                                                                       StrokeThickness="1.5"
                                                                       StrokeDashArray="5 3"
                                                                       Opacity="0.35"
                                                                       IsHitTestVisible="False"
                                                                       Visibility="{Binding HasSelectedSlot, Converter={StaticResource BoolToVisibility}}" />
                                                            <!-- Grid lines -->
                                                            <ItemsControl ItemsSource="{Binding SlotLinePositions}"
                                                                          Canvas.Left="0" Canvas.Top="0"
                                                                          Visibility="{Binding DataContext.ShowItineraryGrid, RelativeSource={RelativeSource AncestorType=Window}, Converter={StaticResource BoolToVisibility}}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate><Canvas /></ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemContainerStyle>
                                                                    <Style TargetType="ContentPresenter">
                                                                        <Setter Property="Canvas.Left" Value="{Binding}" />
                                                                        <Setter Property="Canvas.Top" Value="0" />
                                                                    </Style>
                                                                </ItemsControl.ItemContainerStyle>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Line X1="0" Y1="0" X2="0"
                                                                              Y2="{Binding DataContext.CanvasHeight, RelativeSource={RelativeSource AncestorType=ScrollViewer}}"
                                                                              Stroke="#44000000" StrokeThickness="1" StrokeDashArray="3,4" />
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                            <ItemsControl ItemsSource="{Binding Activities}"
                                                                          Canvas.Left="0" Canvas.Top="0"
                                                                          Width="{Binding CanvasWidth}" Height="{Binding CanvasHeight}">
                                                                <ItemsControl.ItemsPanel>
                                                                    <ItemsPanelTemplate>
                                                                        <Canvas />
                                                                    </ItemsPanelTemplate>
                                                                </ItemsControl.ItemsPanel>
                                                                <ItemsControl.ItemContainerStyle>
                                                                    <Style TargetType="ContentPresenter">
                                                                        <Setter Property="Canvas.Left" Value="{Binding CanvasLeft}" />
                                                                        <Setter Property="Canvas.Top" Value="4" />
                                                                    </Style>
                                                                </ItemsControl.ItemContainerStyle>
                                                                <ItemsControl.ItemTemplate>
                                                                    <DataTemplate>
                                                                        <Grid Width="{Binding BlockWidth}" Height="{Binding BlockHeight}"
                                                                              MouseLeftButtonDown="ActivityBlock_MouseDown"
                                                                              MouseMove="ActivityBlock_MouseMove"
                                                                              MouseLeftButtonUp="ActivityBlock_MouseUp">
                                                                            <Grid.Style>
                                                                                <Style TargetType="Grid">
                                                                                    <Setter Property="Opacity" Value="1" />
                                                                                    <Style.Triggers>
                                                                                        <DataTrigger Binding="{Binding IsRefeicao}" Value="True">
                                                                                            <Setter Property="Opacity" Value="0.65" />
                                                                                        </DataTrigger>
                                                                                        <DataTrigger Binding="{Binding IsDimmed}" Value="True">
                                                                                            <Setter Property="Opacity" Value="0.25" />
                                                                                        </DataTrigger>
                                                                                    </Style.Triggers>
                                                                                </Style>
                                                                            </Grid.Style>
                                                                            <Border>
                                                                                <Border.Style>
                                                                                    <Style TargetType="Border">
                                                                                        <Setter Property="CornerRadius" Value="5" />
                                                                                        <Setter Property="VerticalAlignment" Value="Stretch" />
                                                                                        <Setter Property="Background" Value="{Binding DisplayColor, Converter={StaticResource StringToBrush}}" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsPernoite}" Value="True">
                                                                                                <Setter Property="CornerRadius" Value="20" />
                                                                                                <Setter Property="VerticalAlignment" Value="Center" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Border.Style>
                                                                                <StackPanel VerticalAlignment="Center">
                                                                                    <StackPanel.Style>
                                                                                        <Style TargetType="StackPanel">
                                                                                            <Setter Property="Margin" Value="5,2" />
                                                                                            <Style.Triggers>
                                                                                                <DataTrigger Binding="{Binding IsPernoite}" Value="True">
                                                                                                    <Setter Property="Margin" Value="10,5" />
                                                                                                </DataTrigger>
                                                                                            </Style.Triggers>
                                                                                        </Style>
                                                                                    </StackPanel.Style>
                                                                                    <Grid>
                                                                                        <Grid.ColumnDefinitions>
                                                                                            <ColumnDefinition Width="Auto" />
                                                                                            <ColumnDefinition Width="*" />
                                                                                        </Grid.ColumnDefinitions>
                                                                                        <TextBlock Grid.Column="0" Text="{Binding DisplayIcon}"
                                                                                                   FontFamily="Segoe UI Emoji"
                                                                                                   FontSize="{Binding IconFontSize}" Margin="0,0,3,0" VerticalAlignment="Top"
                                                                                                   Foreground="{Binding DisplayTextColor, Converter={StaticResource StringToBrush}}" />
                                                                                        <TextBlock Grid.Column="1" Text="{Binding DisplayTitle}"
                                                                                                   FontSize="{Binding FontSize}" FontWeight="SemiBold"
                                                                                                   Foreground="{Binding DisplayTextColor, Converter={StaticResource StringToBrush}}"
                                                                                                   VerticalAlignment="Center" TextAlignment="Center" TextWrapping="Wrap" />
                                                                                    </Grid>
                                                                                    <TextBlock Text="{Binding DisplayDetails}"
                                                                                               FontSize="{Binding DetailsFontSize}" HorizontalAlignment="Center"
                                                                                               TextAlignment="Center" TextWrapping="Wrap"
                                                                                               Foreground="{Binding DisplayTextColor, Converter={StaticResource StringToBrush}}"
                                                                                               Opacity="0.78">
                                                                                        <TextBlock.Style>
                                                                                            <Style TargetType="TextBlock">
                                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                                                <Style.Triggers>
                                                                                                    <DataTrigger Binding="{Binding DisplayHasDetails}" Value="True">
                                                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                                                    </DataTrigger>
                                                                                                </Style.Triggers>
                                                                                            </Style>
                                                                                        </TextBlock.Style>
                                                                                    </TextBlock>
                                                                                </StackPanel>
                                                                            </Border>
                                                                            <Border CornerRadius="6" BorderThickness="2" Background="Transparent">
                                                                                <Border.Style>
                                                                                    <Style TargetType="Border">
                                                                                        <Setter Property="BorderBrush" Value="Transparent" />
                                                                                        <Style.Triggers>
                                                                                            <DataTrigger Binding="{Binding IsOverlapping}" Value="True">
                                                                                                <Setter Property="BorderBrush" Value="#EF4444" />
                                                                                            </DataTrigger>
                                                                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                                                                <Setter Property="BorderBrush" Value="#2563EB" />
                                                                                            </DataTrigger>
                                                                                        </Style.Triggers>
                                                                                    </Style>
                                                                                </Border.Style>
                                                                            </Border>
                                                                        </Grid>
                                                                    </DataTemplate>
                                                                </ItemsControl.ItemTemplate>
                                                            </ItemsControl>
                                                        </Canvas>
                                                    </ScrollViewer>

                                                    <!-- Inline edit form (Row 1) -->
                                                    <Border Grid.Row="1" Tag="ItineraryEditForm" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Padding="14,12">
                                                        <Border.Style>
                                                            <Style TargetType="Border">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding HasEditingBlock}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Border.Style>
                                                        <Grid>
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="*" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                                <ColumnDefinition Width="Auto" />
                                                            </Grid.ColumnDefinitions>
                                                            <Grid.RowDefinitions>
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                                <RowDefinition Height="Auto" />
                                                            </Grid.RowDefinitions>

                                                            <StackPanel Grid.Row="0" Margin="0,0,10,8">
                                                                <TextBlock Text="Título" Style="{StaticResource Caption}" />
                                                                <TextBox Text="{Binding EditingActivity.EditTitle, UpdateSourceTrigger=PropertyChanged}" Height="32" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Row="0" Grid.Column="1" Margin="0,0,10,8">
                                                                <TextBlock Text="Duração (blocos)" Style="{StaticResource Caption}" />
                                                                <TextBox Text="{Binding EditingActivity.EditDurationSlots, UpdateSourceTrigger=PropertyChanged}" Height="32" Width="110" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Row="0" Grid.Column="2" Margin="0,0,10,8">
                                                                <TextBlock Text="Tipo" Style="{StaticResource Caption}" />
                                                                <ComboBox ItemsSource="{x:Static local:ItineraryActivityViewModel.TypeOptions}"
                                                                          SelectedItem="{Binding EditingActivity.EditType, UpdateSourceTrigger=PropertyChanged}"
                                                                          Height="32" Width="110"
                                                                          DropDownOpened="EditTypeCombo_DropDownOpened"
                                                                          DropDownClosed="EditTypeCombo_DropDownClosed" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Row="0" Grid.Column="3" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="0,0,0,8">
                                                                <Button Style="{StaticResource CardActionButton}" ToolTip="Aceitar (Enter)" Click="AcceptEdit_Click" Margin="0,0,2,0">
                                                                    <TextBlock Text="&#xE73E;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                                                </Button>
                                                                <Button Style="{StaticResource CardActionButton}" ToolTip="Rejeitar (Esc)" Click="RejectEdit_Click" Margin="0,0,2,0">
                                                                    <TextBlock Text="&#xE711;" FontFamily="Segoe MDL2 Assets" FontSize="11" />
                                                                </Button>
                                                                <Button Style="{StaticResource CardActionButton}" ToolTip="Excluir atividade" Click="DeleteEditActivity_Click">
                                                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="11" Opacity="0.72" />
                                                                </Button>
                                                            </StackPanel>

                                                            <StackPanel Grid.Row="1" Margin="0,0,10,8">
                                                                <TextBlock Text="Detalhes" Style="{StaticResource Caption}" />
                                                                <TextBox Text="{Binding EditingActivity.EditDetails, UpdateSourceTrigger=PropertyChanged}"
                                                                         Height="64" TextWrapping="Wrap"
                                                                         VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                                                                         PreviewKeyDown="MultilineEditField_PreviewKeyDown" />
                                                            </StackPanel>
                                                            <StackPanel Grid.Row="1" Grid.Column="1" Grid.ColumnSpan="3" Margin="0,0,0,8">
                                                                <TextBlock Text="Dados adicionais" Style="{StaticResource Caption}" />
                                                                <TextBox Text="{Binding EditingActivity.EditAdditionalData, UpdateSourceTrigger=PropertyChanged}"
                                                                         Height="64" TextWrapping="Wrap"
                                                                         VerticalScrollBarVisibility="Auto" VerticalContentAlignment="Top"
                                                                         PreviewKeyDown="MultilineEditField_PreviewKeyDown" />
                                                            </StackPanel>

                                                            <DockPanel Grid.Row="2" Grid.ColumnSpan="4">
                                                                <Button DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                                                                        Style="{StaticResource SecondaryButton}" Click="CopyEditActivity_Click">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#xE8C8;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                                        <TextBlock Text="Duplicar Atividade" VerticalAlignment="Center" />
                                                                    </StackPanel>
                                                                </Button>
                                                                <Button DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                                                                        Style="{StaticResource SecondaryButton}" Click="PasteStyleActivity_Click"
                                                                        IsEnabled="{Binding DataContext.HasStyleClipboard, RelativeSource={RelativeSource AncestorType=Window}}"
                                                                        ToolTip="Colar estilo copiado (Ctrl+V)">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#xE77F;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                                        <TextBlock Text="Colar Estilo" VerticalAlignment="Center" />
                                                                    </StackPanel>
                                                                </Button>
                                                                <Button DockPanel.Dock="Right" VerticalAlignment="Center" Margin="8,0,0,0"
                                                                        Style="{StaticResource SecondaryButton}" Click="CopyStyleActivity_Click"
                                                                        ToolTip="Copiar estilo do bloco (Ctrl+C)">
                                                                    <StackPanel Orientation="Horizontal">
                                                                        <TextBlock Text="&#xEF90;" FontFamily="Segoe MDL2 Assets" FontSize="11" VerticalAlignment="Center" Margin="0,0,6,0" />
                                                                        <TextBlock Text="Copiar Estilo" VerticalAlignment="Center" />
                                                                    </StackPanel>
                                                                </Button>
                                                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                                    <TextBlock Text="Ícone" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="0,0,8,0" />
                                                                    <WrapPanel VerticalAlignment="Center">
                                                                        <Button Tag="" Style="{StaticResource IconPickerButton}" ToolTip="Nenhum" Click="EditActivityIcon_Click">
                                                                            <TextBlock Text="✕" FontSize="13" VerticalAlignment="Center" HorizontalAlignment="Center" />
                                                                        </Button>
                                                                        <Button Tag="✈" Style="{StaticResource IconPickerButton}" ToolTip="Avião" Click="EditActivityIcon_Click"><TextBlock Text="✈" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="🚗" Style="{StaticResource IconPickerButton}" ToolTip="Carro" Click="EditActivityIcon_Click"><TextBlock Text="🚗" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="🚌" Style="{StaticResource IconPickerButton}" ToolTip="Ônibus" Click="EditActivityIcon_Click"><TextBlock Text="🚌" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="🚢" Style="{StaticResource IconPickerButton}" ToolTip="Barco" Click="EditActivityIcon_Click"><TextBlock Text="🚢" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="🚶" Style="{StaticResource IconPickerButton}" ToolTip="Caminhada" Click="EditActivityIcon_Click"><TextBlock Text="🚶" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="🍴" Style="{StaticResource IconPickerButton}" ToolTip="Restaurante" Click="EditActivityIcon_Click"><TextBlock Text="🍴" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="🛏" Style="{StaticResource IconPickerButton}" ToolTip="Hospedagem" Click="EditActivityIcon_Click"><TextBlock Text="🛏" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="📷" Style="{StaticResource IconPickerButton}" ToolTip="Câmera" Click="EditActivityIcon_Click"><TextBlock Text="📷" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="📍" Style="{StaticResource IconPickerButton}" ToolTip="Ponto no mapa" Click="EditActivityIcon_Click"><TextBlock Text="📍" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="🎫" Style="{StaticResource IconPickerButton}" ToolTip="Ingresso" Click="EditActivityIcon_Click"><TextBlock Text="🎫" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="⛺" Style="{StaticResource IconPickerButton}" ToolTip="Acampamento" Click="EditActivityIcon_Click"><TextBlock Text="⛺" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="🥤" Style="{StaticResource IconPickerButton}" ToolTip="Lanche" Click="EditActivityIcon_Click"><TextBlock Text="🥤" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="🛒" Style="{StaticResource IconPickerButton}" ToolTip="Compras" Click="EditActivityIcon_Click"><TextBlock Text="🛒" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                        <Button Tag="💩" Style="{StaticResource IconPickerButton}" ToolTip="Cocô" Click="EditActivityIcon_Click"><TextBlock Text="💩" FontFamily="Segoe UI Emoji" FontSize="17" /></Button>
                                                                    </WrapPanel>
                                                                    <TextBlock Text="Cor" Style="{StaticResource Caption}" VerticalAlignment="Center" Margin="16,0,8,0" />
                                                                    <Button Width="34" Height="34" MinHeight="34" VerticalAlignment="Center"
                                                                            Background="{Binding EditingActivity.EditColor, Converter={StaticResource StringToBrush}}"
                                                                            BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="1"
                                                                            Style="{StaticResource ButtonBase}"
                                                                            Click="EditActivityColor_Click"
                                                                            ToolTip="Escolher cor" />
                                                                </StackPanel>
                                                            </DockPanel>
                                                        </Grid>
                                                    </Border>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </Grid>
                            </Grid>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- Footer -->
                <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,12,0,0">
                    <Button Content="Salvar Roteiro" Style="{StaticResource PrimaryButton}" Click="SaveItinerary_Click" />
                </StackPanel>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0">
                <Grid Margin="24,0">
                    <TextBlock Text="☁  Salvo automaticamente" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{StaticResource MutedTextBrush}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
