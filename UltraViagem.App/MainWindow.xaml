<Window x:Class="UltraViagem.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:local="clr-namespace:UltraViagem.App"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="UltraViagem"
        Height="900"
        MinHeight="760"
        Width="1360"
        MinWidth="1180"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource PageBackground}">
    <Window.Resources>
        <local:AttachmentIconConverter x:Key="AttachmentIconConverter" />
        <local:AttachmentMetadataConverter x:Key="AttachmentMetadataConverter" />
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="{StaticResource SidebarBackground}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,1,0">
            <DockPanel Margin="14,18" LastChildFill="False">
                <StackPanel DockPanel.Dock="Top">
                    <Grid Margin="0,0,0,28">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="48" />
                            <ColumnDefinition Width="*" />
                        </Grid.ColumnDefinitions>
                        <Image Source="Assets/AppIcon/app-icon.png"
                               Width="32"
                               Height="32"
                               VerticalAlignment="Center"
                               RenderOptions.BitmapScalingMode="HighQuality" />
                        <TextBlock Grid.Column="1" Text="UltraViagem" FontSize="20" FontWeight="Bold" VerticalAlignment="Center" Foreground="#0E4C49" />
                    </Grid>

                    <Button x:Name="OverviewNavButton" Style="{StaticResource NavButton}" Click="ShowOverview_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE80F;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Visão Geral" Style="{StaticResource NavLabel}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="TripDetailsNavButton" Style="{StaticResource NavButton}" Click="EditTrip_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Dados da viagem" Style="{StaticResource NavLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8FD;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Roteiro" Style="{StaticResource NavLabel}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="TasksNavButton" Style="{StaticResource NavButton}" Click="ShowTasks_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73A;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Tarefas" Style="{StaticResource NavLabel}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="MapNavButton" Style="{StaticResource NavButton}" Click="ShowMap_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE707;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Mapa" Style="{StaticResource NavLabel}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="BudgetNavButton" Style="{StaticResource NavButton}" Click="ShowBudget_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="R$" Style="{StaticResource NavIcon}" FontFamily="Segoe UI" FontSize="15" FontWeight="Bold" />
                            <TextBlock Text="Gastos" Style="{StaticResource NavLabel}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="TipsNavButton" Style="{StaticResource NavButton}" Click="ShowTips_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8BD;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Dicas" Style="{StaticResource NavLabel}" />
                        </StackPanel>
                    </Button>
                    <Button x:Name="FilesNavButton" Style="{StaticResource NavButton}" Click="ShowFiles_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8B7;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Arquivos" Style="{StaticResource NavLabel}" />
                        </StackPanel>
                    </Button>
                </StackPanel>

                <StackPanel DockPanel.Dock="Bottom">
                    <Button Style="{StaticResource NavButton}" IsEnabled="False">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE713;" Style="{StaticResource NavIcon}" />
                            <TextBlock Text="Configurações" Style="{StaticResource NavLabel}" />
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource NavButton}" Click="ShowAbout_Click">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="!"
                                       Style="{StaticResource NavIcon}"
                                       FontFamily="Segoe UI"
                                       FontWeight="SemiBold" />
                            <TextBlock Text="Sobre" Style="{StaticResource NavLabel}" />
                        </StackPanel>
                    </Button>
                    <Border Background="{StaticResource SidebarPanelBackground}" CornerRadius="8" Padding="12" Margin="0,16,0,0">
                        <StackPanel>
                            <TextBlock Text="Repositório" Style="{StaticResource Caption}" />
                            <Button Style="{StaticResource LinkButton}" Click="OpenRepositoryFolder_Click" Margin="0,5,0,12" ToolTip="Abrir pasta do repositório">
                                <TextBlock Text="{Binding RootPath}" TextWrapping="Wrap" FontSize="12" Foreground="{StaticResource AccentBrush}" TextDecorations="Underline" />
                            </Button>
                            <Button Content="Selecionar Pasta" Style="{StaticResource SecondaryButton}" Click="SelectRepository_Click" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="84" />
                <RowDefinition Height="*" />
                <RowDefinition Height="44" />
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <Button Height="58"
                            Style="{StaticResource SecondaryButton}"
                            Background="#FFFEFB"
                            BorderBrush="{StaticResource BorderBrushSoft}"
                            BorderThickness="1"
                            Foreground="{StaticResource TextBrush}"
                            Padding="0"
                            Click="OpenTripSelection_Click"
                            HorizontalAlignment="Left"
                            HorizontalContentAlignment="Stretch"
                            VerticalAlignment="Center"
                            Margin="-8,0,0,0">
                        <Grid Margin="12,0,14,0" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="38" />
                                <ColumnDefinition Width="Auto" />
                                <ColumnDefinition Width="26" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="&#xE821;"
                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Foreground="{StaticResource AccentBrush}"
                                       HorizontalAlignment="Left"
                                       VerticalAlignment="Center"
                                       FontSize="24" />
                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding TripTitle}" FontWeight="SemiBold" FontSize="14" TextAlignment="Left" />
                                <TextBlock Text="{Binding TripSubtitle}" Style="{StaticResource Caption}" />
                            </StackPanel>
                            <TextBlock Grid.Column="2"
                                       Text="▼"
                                       FontFamily="Segoe UI"
                                       FontSize="10"
                                       Foreground="{StaticResource TextBrush}"
                                       VerticalAlignment="Center"
                                       HorizontalAlignment="Right"
                                       Margin="14,2,0,0" />
                        </Grid>
                    </Button>

                    <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Margin="20,0,0,0">
                        <Button Style="{StaticResource PrimaryButton}" Content="+  Nova Viagem" Click="NewTrip_Click" />
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer x:Name="OverviewPanel" Grid.Row="1" VerticalScrollBarVisibility="Auto">
                <Grid Margin="24,22,24,18">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0" Margin="0,0,0,24">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="{Binding TripTitle}" FontSize="28" FontWeight="Bold" VerticalAlignment="Center" />
                                <Button Margin="8,3,0,0"
                                        Padding="0"
                                        VerticalAlignment="Center"
                                        Click="ToggleCurrentTripFavorite_Click">
                                    <TextBlock Text="{Binding CurrentTripFavoriteGlyph}"
                                               FontSize="24"
                                               FontWeight="Normal" />
                                    <Button.Style>
                                        <Style TargetType="Button" BasedOn="{StaticResource LinkButton}">
                                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                            <Setter Property="ToolTip" Value="Marcar viagem como favorita" />
                                            <Style.Resources>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                                </Style>
                                            </Style.Resources>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentTripFavorite}" Value="True">
                                                    <Setter Property="ToolTip" Value="Remover viagem dos favoritos" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Style>
                                    <Button.Resources>
                                        <Style TargetType="TextBlock">
                                            <Setter Property="Foreground" Value="{StaticResource MutedTextBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsCurrentTripFavorite}" Value="True">
                                                    <Setter Property="Foreground" Value="#E3A008" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </StackPanel>
                            <TextBlock Text="{Binding TripSubtitle}" Foreground="{StaticResource MutedTextBrush}" FontSize="14" Margin="0,4,0,0" />
                        </StackPanel>
                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                            <Button Style="{StaticResource SecondaryButton}" Content="‹" FontSize="24" Width="42" Margin="0,0,8,0" IsEnabled="False" />
                            <Button Style="{StaticResource SecondaryButton}" Content="›" FontSize="24" Width="42" IsEnabled="False" />
                        </StackPanel>
                    </Grid>

                    <Border Grid.Row="1" Margin="0,0,0,26">
                        <StackPanel>
                            <TextBlock FontSize="16" Margin="2,0,0,12">
                                <Run Text="Roteiro" FontWeight="SemiBold" />
                                <Run Text=" — Visão geral do dia a dia" Foreground="{StaticResource MutedTextBrush}" />
                            </TextBlock>
                            <ItemsControl ItemsSource="{Binding Itinerary}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,0,24,0">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="28" />
                                                <ColumnDefinition Width="270" />
                                            </Grid.ColumnDefinitions>
                                            <Border Width="28" Height="28" CornerRadius="14" Background="{StaticResource AccentBrush}" VerticalAlignment="Center">
                                                <TextBlock Text="•" Foreground="White" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,-6,0,0" />
                                            </Border>
                                            <Border Grid.Column="1" Style="{StaticResource Card}" Width="270" MinHeight="218" Padding="14">
                                                <StackPanel>
                                                    <Grid>
                                                        <TextBlock Text="{Binding Title}" FontSize="17" FontWeight="SemiBold" />
                                                        <TextBlock Text="{Binding DateLabel}" Style="{StaticResource Caption}" HorizontalAlignment="Right" />
                                                    </Grid>
                                                    <Grid Margin="0,12,0,10">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="74" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="64" Height="64" CornerRadius="7" Background="{StaticResource AccentSoftBrush}">
                                                            <TextBlock Text="▧" Foreground="{StaticResource AccentBrush}" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding OvernightLabel}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                            <TextBlock Text="Chile" Style="{StaticResource Caption}" Margin="0,4,0,0" />
                                                        </StackPanel>
                                                    </Grid>
                                                    <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0" Margin="0,2,0,10" />
                                                    <ItemsControl ItemsSource="{Binding Blocks}">
                                                        <ItemsControl.ItemTemplate>
                                                            <DataTemplate>
                                                                <TextBlock Text="{Binding}" TextWrapping="Wrap" Margin="0,0,0,7" Foreground="#3E4946" />
                                                            </DataTemplate>
                                                        </ItemsControl.ItemTemplate>
                                                    </ItemsControl>
                                                    <TextBlock Text="Ver detalhes  ›" Foreground="{StaticResource AccentBrush}" FontWeight="SemiBold" Margin="0,8,0,0" />
                                                </StackPanel>
                                            </Border>
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="2">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.12*" />
                            <ColumnDefinition Width="1.12*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE73A;" Style="{StaticResource SectionIcon}" />
                                        <TextBlock Text="Tarefas" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                        <Button Content="›" Style="{StaticResource ArrowButton}" Click="ShowTasks_Click" ToolTip="Abrir tarefas" />
                                    </StackPanel>
                                </Grid>

                                <ItemsControl Grid.Row="1" ItemsSource="{Binding Tasks}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="28" />
                                                    <ColumnDefinition Width="*" />
                                                </Grid.ColumnDefinitions>
                                                <CheckBox IsChecked="{Binding IsDone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Center" />
                                                <TextBlock Grid.Column="1" Text="{Binding Title}" TextWrapping="Wrap" VerticalAlignment="Center">
                                                    <TextBlock.Style>
                                                        <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                    <Setter Property="Foreground" Value="#8B928F" />
                                                                    <Setter Property="TextDecorations" Value="Strikethrough" />
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </TextBlock.Style>
                                                </TextBlock>
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>

                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,14">
                                    <StackPanel Orientation="Horizontal">
                                <TextBlock Text="R$" Style="{StaticResource SectionIcon}" FontFamily="Segoe UI" FontSize="15" FontWeight="Bold" />
                                        <TextBlock Text="Gastos" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button Content="›" Style="{StaticResource ArrowButton}" HorizontalAlignment="Right" Click="ShowBudget_Click" ToolTip="Abrir gastos" />
                                </Grid>
                                <UniformGrid Columns="3" Margin="0,0,0,16">
                                    <StackPanel>
                                        <TextBlock Text="Total estimado" Style="{StaticResource Caption}" />
                                        <TextBlock Text="{Binding EstimatedTotal}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold" FontSize="14" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Pago" Style="{StaticResource Caption}" />
                                        <TextBlock Text="{Binding PaidTotal}" Foreground="#15803D" FontWeight="Bold" FontSize="14" />
                                    </StackPanel>
                                    <StackPanel>
                                        <TextBlock Text="Pendente" Style="{StaticResource Caption}" />
                                        <TextBlock Text="{Binding PendingTotal}" Foreground="#B42318" FontWeight="Bold" FontSize="14" />
                                    </StackPanel>
                                </UniformGrid>
                                <TextBlock Text="Por categoria" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,8" />
                                <ItemsControl ItemsSource="{Binding BudgetCategories}">
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Grid Margin="0,7">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="94" />
                                                    <ColumnDefinition Width="*" />
                                                    <ColumnDefinition Width="84" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                                <Border Grid.Column="1" Background="#E8E2D7" CornerRadius="4" Height="12" VerticalAlignment="Center">
                                                    <Border Background="{StaticResource AccentBrush}" CornerRadius="4" HorizontalAlignment="Left" Width="{Binding BarWidth}" />
                                                </Border>
                                                <TextBlock Grid.Column="2" Text="{Binding TotalLabel}" TextAlignment="Right" VerticalAlignment="Center" FontSize="12" />
                                            </Grid>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </StackPanel>
                        </Border>

                        <Border Grid.Column="2" Style="{StaticResource Card}" Margin="0,0,12,0">
                            <StackPanel>
                                <Grid Margin="0,0,0,12">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE707;" Style="{StaticResource SectionIcon}" />
                                        <TextBlock Text="Mapa" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button Content="›" Style="{StaticResource ArrowButton}" HorizontalAlignment="Right" Click="ShowMap_Click" ToolTip="Abrir mapa" />
                                </Grid>
                                <Border Height="250" Background="#DDE8DF" CornerRadius="8" Margin="0,0,0,12" ClipToBounds="True">
                                    <Grid>
                                        <wv2:WebView2 x:Name="OverviewMapBrowser" />
                                        <TextBlock x:Name="OverviewMapPlaceholder"
                                                   Text="Cadastre o link público do Google My Maps na tela Mapa."
                                                   TextWrapping="Wrap"
                                                   TextAlignment="Center"
                                                   Foreground="{StaticResource MutedTextBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"
                                                   Margin="24" />
                                    </Grid>
                                </Border>
                                <Button Content="Abrir no navegador" Style="{StaticResource SecondaryButton}" Click="OpenMyMaps_Click" />
                            </StackPanel>
                        </Border>

                    </Grid>

                    <Grid Grid.Row="3" Margin="0,18,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1*" />
                            <ColumnDefinition Width="1*" />
                        </Grid.ColumnDefinitions>

                        <Border Grid.Column="0" Style="{StaticResource Card}" Margin="0,0,12,0" MinHeight="250">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="42" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8BD;" Style="{StaticResource SectionIcon}" />
                                        <TextBlock Text="Dicas" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="›" Style="{StaticResource ArrowButton}" HorizontalAlignment="Right" Click="ShowTips_Click" ToolTip="Abrir dicas" />
                                </Grid>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,8,0" PreviewMouseWheel="OverviewCard_PreviewMouseWheel">
                                    <ItemsControl ItemsSource="{Binding OverviewTips}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="0,8">
                                                    <StackPanel>
                                                        <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap" />
                                                        <Grid>
                                                            <Button x:Name="OverviewTipLinkButton"
                                                                    Style="{StaticResource LinkButton}"
                                                                    Click="OpenTipLink_Click"
                                                                    ToolTip="Abrir link">
                                                                <TextBlock Text="{Binding Url}" Foreground="{StaticResource AccentBrush}" FontSize="12" TextWrapping="Wrap" />
                                                            </Button>
                                                            <TextBlock x:Name="OverviewTipText"
                                                                       Text="{Binding Url}"
                                                                       Foreground="{StaticResource MutedTextBrush}"
                                                                       FontSize="12"
                                                                       TextWrapping="Wrap"
                                                                       Visibility="Collapsed" />
                                                        </Grid>
                                                    </StackPanel>
                                                </Border>
                                                <DataTemplate.Triggers>
                                                    <DataTrigger Binding="{Binding HasValidUrl}" Value="False">
                                                        <Setter TargetName="OverviewTipLinkButton" Property="Visibility" Value="Collapsed" />
                                                        <Setter TargetName="OverviewTipText" Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </DataTemplate.Triggers>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                            </Grid>
                        </Border>

                        <Border Grid.Column="1" Style="{StaticResource Card}" MinHeight="250">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <Grid Grid.Row="0" Margin="0,0,0,12">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="42" />
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8B7;" Style="{StaticResource SectionIcon}" />
                                        <TextBlock Text="Arquivos" Style="{StaticResource SectionTitle}" VerticalAlignment="Center" />
                                    </StackPanel>
                                    <Button Grid.Column="1" Content="›" Style="{StaticResource ArrowButton}" HorizontalAlignment="Right" Click="ShowFiles_Click" ToolTip="Abrir arquivos" />
                                </Grid>

                                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Margin="0,0,8,0" PreviewMouseWheel="OverviewCard_PreviewMouseWheel">
                                    <ItemsControl ItemsSource="{Binding OverviewFiles}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <Border BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,0,0,1" Padding="0,10">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="44" />
                                                            <ColumnDefinition Width="*" />
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="34" Height="38" CornerRadius="4" Background="#F7F9F8">
                                                            <Image Width="30" Height="30" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                                <Image.Source>
                                                                    <MultiBinding Converter="{StaticResource AttachmentIconConverter}">
                                                                        <Binding Path="File" />
                                                                        <Binding Path="DataContext.TripPath" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                    </MultiBinding>
                                                                </Image.Source>
                                                            </Image>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding File}" TextWrapping="Wrap" FontWeight="SemiBold" />
                                                            <TextBlock Foreground="{StaticResource MutedTextBrush}" FontSize="12" Margin="0,2,0,0">
                                                                <TextBlock.Text>
                                                                    <MultiBinding Converter="{StaticResource AttachmentMetadataConverter}">
                                                                        <Binding Path="File" />
                                                                        <Binding Path="DataContext.TripPath" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                                    </MultiBinding>
                                                                </TextBlock.Text>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Grid>
                                                </Border>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>
                                </ScrollViewer>

                            </Grid>
                        </Border>
                    </Grid>
                </Grid>
            </ScrollViewer>

            <Grid x:Name="TripDetailsPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18">
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,22">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE713;" Style="{StaticResource PanelTitleIcon}" />
                                        <TextBlock Text="Dados da viagem" Style="{StaticResource PanelTitleText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Edite as informações gerais da viagem atual." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" ToolTip="Voltar para visão geral" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" MaxWidth="960" HorizontalAlignment="Stretch">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.ColumnSpan="2">
                                <TextBlock Text="Nome" Style="{StaticResource Caption}" />
                                <TextBox x:Name="TripDetailsTitleBox" Padding="10" FontSize="16" Margin="0,4,0,14" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,14,0">
                                <TextBlock Text="Data inicial" Style="{StaticResource Caption}" />
                                <DatePicker x:Name="TripDetailsStartDatePicker" Margin="0,4,0,14" Height="34" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Grid.Column="1">
                                <TextBlock Text="Data final" Style="{StaticResource Caption}" />
                                <DatePicker x:Name="TripDetailsEndDatePicker" Margin="0,4,0,14" Height="34" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Margin="0,0,14,0">
                                <TextBlock Text="Pessoas" Style="{StaticResource Caption}" />
                                <TextBox x:Name="TripDetailsPeopleBox" Padding="10" Margin="0,4,0,14" />
                            </StackPanel>

                            <StackPanel Grid.Row="2" Grid.Column="1">
                                <TextBlock Text="Moeda" Style="{StaticResource Caption}" />
                                <TextBox x:Name="TripDetailsCurrencyBox" Padding="10" Margin="0,4,0,14" />
                            </StackPanel>

                            <StackPanel Grid.Row="3" Grid.ColumnSpan="2" Margin="0,0,0,14">
                                <TextBlock Text="Pasta da viagem" Style="{StaticResource Caption}" />
                                <DockPanel Margin="0,4,0,0">
                                    <Button DockPanel.Dock="Right"
                                            Content="Renomear Pasta"
                                            Style="{StaticResource SecondaryButton}"
                                            Click="RenameTripFolder_Click"
                                            Margin="10,0,0,0" />
                                    <TextBox x:Name="TripDetailsPathBox"
                                             IsReadOnly="True"
                                             MinWidth="620"
                                             Padding="10"
                                             TextWrapping="NoWrap"
                                             ToolTip="{Binding TripPath}" />
                                </DockPanel>
                            </StackPanel>

                            <TextBlock Grid.Row="4"
                                       Grid.ColumnSpan="2"
                                       x:Name="TripDetailsErrorText"
                                       Foreground="#B42318"
                                       TextWrapping="Wrap"
                                       Visibility="Collapsed" />
                        </Grid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button Content="Salvar Dados" Style="{StaticResource PrimaryButton}" Click="SaveTripDetails_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="BudgetPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18">
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Margin="0,0,0,12">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="R$" Style="{StaticResource PanelTitleIcon}" FontFamily="Segoe UI" FontSize="16" FontWeight="Bold" />
                                <StackPanel>
                                    <TextBlock Text="Gastos" Style="{StaticResource PanelTitleText}" />
                                    <TextBlock Text="{Binding BudgetSubtitle}" Foreground="{StaticResource MutedTextBrush}" Margin="0,0,0,0" />
                                </StackPanel>
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" ToolTip="Voltar para visão geral" Margin="0,0,10,0" />
                                <Button Content="Novo" Style="{StaticResource SecondaryButton}" Click="AddExpense_Click" Margin="0,0,10,0" />
                                <Button Content="Excluir" Style="{StaticResource SecondaryButton}" Click="DeleteExpense_Click" />
                            </StackPanel>
                        </Grid>

                        <DataGrid Grid.Row="1"
                                  ItemsSource="{Binding Expenses}"
                                  SelectedItem="{Binding SelectedExpense}"
                                  AutoGenerateColumns="False"
                                  CanUserAddRows="False"
                                  HeadersVisibility="Column"
                                  RowHeaderWidth="0"
                                  GridLinesVisibility="Horizontal"
                                  HorizontalScrollBarVisibility="Auto">
                            <DataGrid.Columns>
                                <DataGridCheckBoxColumn Header="Ativo" Binding="{Binding IsActive, UpdateSourceTrigger=PropertyChanged}" Width="58" />
                                <DataGridTextColumn Header="Categoria" Binding="{Binding Type, UpdateSourceTrigger=PropertyChanged}" Width="115" />
                                <DataGridTextColumn Header="Descrição" Binding="{Binding Title, UpdateSourceTrigger=PropertyChanged}" Width="190" />
                                <DataGridTextColumn Header="Empresa" Binding="{Binding Company, UpdateSourceTrigger=PropertyChanged}" Width="130" />
                                <DataGridTextColumn Header="Link" Binding="{Binding Link, UpdateSourceTrigger=PropertyChanged}" Width="160" />
                                <DataGridTextColumn Header="Obs" Binding="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" Width="180" />
                                <DataGridTextColumn Header="Preço unit." Binding="{Binding Price, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="92" />
                                <DataGridTextColumn Header="Taxas unit." Binding="{Binding Taxes, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="92" />
                                <DataGridTextColumn Header="Pessoas" Binding="{Binding People, UpdateSourceTrigger=PropertyChanged}" Width="72" />
                                <DataGridTextColumn Header="Quant." Binding="{Binding Quantity, UpdateSourceTrigger=PropertyChanged}" Width="68" />
                                <DataGridTextColumn Header="Subtotal" Binding="{Binding Subtotal, StringFormat=N2}" IsReadOnly="True" Width="92" />
                                <DataGridTextColumn Header="Moeda" Binding="{Binding Currency, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                                <DataGridTextColumn Header="Cotação item" Binding="{Binding ExchangeRateToBase, UpdateSourceTrigger=PropertyChanged, StringFormat=N6}" Width="105" />
                                <DataGridTextColumn Header="Convertido BRL" Binding="{Binding SubtotalBase, StringFormat=C}" IsReadOnly="True" Width="120" />
                                <DataGridTextColumn Header="Pago BRL" Binding="{Binding PaidAmount, UpdateSourceTrigger=PropertyChanged, StringFormat=N2}" Width="100" />
                                <DataGridTextColumn Header="Status" Binding="{Binding Status, UpdateSourceTrigger=PropertyChanged}" Width="120" />
                            </DataGrid.Columns>
                        </DataGrid>

                        <Grid Grid.Row="2" Margin="0,16,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*" />
                                <ColumnDefinition Width="1.2*" />
                                <ColumnDefinition Width="1*" />
                            </Grid.ColumnDefinitions>

                            <UniformGrid Columns="3" Margin="0,0,14,0">
                                <Border Background="{StaticResource AccentSoftBrush}" CornerRadius="7" Padding="12" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Total ativo" Style="{StaticResource Caption}" />
                                        <TextBlock Text="{Binding EstimatedTotal}" FontSize="18" FontWeight="Bold" Foreground="{StaticResource AccentBrush}" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#F1F8EF" CornerRadius="7" Padding="12" Margin="0,0,8,0">
                                    <StackPanel>
                                        <TextBlock Text="Pago" Style="{StaticResource Caption}" />
                                        <TextBlock Text="{Binding PaidTotal}" FontSize="16" FontWeight="SemiBold" Foreground="#15803D" />
                                    </StackPanel>
                                </Border>
                                <Border Background="#FFF4ED" CornerRadius="7" Padding="12">
                                    <StackPanel>
                                        <TextBlock Text="Falta pagar" Style="{StaticResource Caption}" />
                                        <TextBlock Text="{Binding PendingTotal}" FontSize="16" FontWeight="SemiBold" Foreground="#B42318" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <ItemsControl Grid.Column="1" ItemsSource="{Binding BudgetCategories}" Margin="0,0,14,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Grid Margin="0,4">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="94" />
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="86" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Name}" VerticalAlignment="Center" />
                                            <Border Grid.Column="1" Background="#E8E2D7" CornerRadius="4" Height="10" VerticalAlignment="Center">
                                                <Border Background="{StaticResource AccentBrush}" CornerRadius="4" HorizontalAlignment="Left" Width="{Binding BarWidth}" />
                                            </Border>
                                            <TextBlock Grid.Column="2" Text="{Binding TotalLabel}" TextAlignment="Right" FontSize="12" VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <StackPanel Grid.Column="2">
                                <DataGrid ItemsSource="{Binding CurrencyRates}"
                                          AutoGenerateColumns="False"
                                          CanUserAddRows="False"
                                          HeadersVisibility="Column"
                                          RowHeaderWidth="0"
                                          Height="112"
                                          Margin="0,0,0,8">
                                    <DataGrid.Columns>
                                        <DataGridTextColumn Header="Moeda" Binding="{Binding Currency, UpdateSourceTrigger=PropertyChanged}" Width="70" />
                                        <DataGridTextColumn Header="Cotação geral" Binding="{Binding RateToBase, UpdateSourceTrigger=PropertyChanged, StringFormat=N6}" Width="*" />
                                    </DataGrid.Columns>
                                </DataGrid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                    <Button Content="Atualizar Cotações" Style="{StaticResource SecondaryButton}" Click="UpdateExchangeRates_Click" Margin="0,0,8,0" />
                                    <Button Content="Salvar Gastos" Style="{StaticResource PrimaryButton}" Click="SaveExpenses_Click" />
                                </StackPanel>
                            </StackPanel>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="TasksPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="380" />
                    <ColumnDefinition Width="*" />
                </Grid.ColumnDefinitions>

                <Border Style="{StaticResource Card}" Margin="0,0,18,0">
                    <DockPanel>
                        <StackPanel DockPanel.Dock="Top">
                            <Grid Margin="0,0,0,2">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE73A;" Style="{StaticResource PanelTitleIcon}" />
                                    <TextBlock Text="Tarefas" Style="{StaticResource PanelTitleText}" />
                                </StackPanel>
                                <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" HorizontalAlignment="Right" ToolTip="Voltar para visão geral" />
                            </Grid>
                            <TextBlock Text="Planeje compras, reservas e pendências da viagem." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,14" />
                            <UniformGrid Columns="3" Margin="0,0,0,14">
                                <Button Content="Todas" Style="{StaticResource SecondaryButton}" Click="ShowAllTasks_Click" Margin="0,0,6,0" />
                                <Button Content="Pendentes" Style="{StaticResource SecondaryButton}" Click="ShowPendingTasks_Click" Margin="0,0,6,0" />
                                <Button Content="Concluídas" Style="{StaticResource SecondaryButton}" Click="ShowDoneTasks_Click" />
                            </UniformGrid>
                        </StackPanel>
                        <ListBox ItemsSource="{Binding Tasks}"
                                 SelectedItem="{Binding SelectedTask}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="24" />
                                            <ColumnDefinition Width="*" />
                                        </Grid.ColumnDefinitions>
                                        <CheckBox IsChecked="{Binding IsDone, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}" VerticalAlignment="Top" />
                                        <StackPanel Grid.Column="1">
                                            <TextBlock Text="{Binding Title}" FontWeight="SemiBold" TextWrapping="Wrap">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock" BasedOn="{StaticResource {x:Type TextBlock}}">
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                                <Setter Property="Foreground" Value="#8B928F" />
                                                                <Setter Property="TextDecorations" Value="Strikethrough" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                            <TextBlock Text="{Binding Notes}" Foreground="{StaticResource MutedTextBrush}" FontSize="12" TextWrapping="Wrap" />
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <Border Grid.Column="1" Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <TextBlock Text="Editar Tarefa" FontSize="24" FontWeight="Bold" />
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                                <Button Content="Nova" Style="{StaticResource SecondaryButton}" Click="AddTask_Click" Margin="0,0,10,0" />
                                <Button Content="Excluir" Style="{StaticResource SecondaryButton}" Click="DeleteTask_Click" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1" DataContext="{Binding SelectedTask}">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <StackPanel Grid.ColumnSpan="2">
                                <TextBlock Text="Título" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}" FontSize="18" Padding="10" Margin="0,4,0,14" />
                            </StackPanel>

                            <StackPanel Grid.Row="1" Margin="0,0,14,0">
                                <TextBlock Text="Status" Foreground="{StaticResource MutedTextBrush}" />
                                <ComboBox SelectedValue="{Binding Status, UpdateSourceTrigger=PropertyChanged}" SelectedValuePath="Tag" Margin="0,4,0,14" Padding="8">
                                    <ComboBoxItem Content="Pendente" Tag="pending" />
                                    <ComboBoxItem Content="Concluída" Tag="done" />
                                </ComboBox>
                            </StackPanel>

                            <StackPanel Grid.Row="2">
                                <TextBlock Text="Notas" Foreground="{StaticResource MutedTextBrush}" />
                                <TextBox Text="{Binding Notes, UpdateSourceTrigger=PropertyChanged}" AcceptsReturn="True" TextWrapping="Wrap" MinHeight="180" Padding="10" Margin="0,4,0,0" />
                            </StackPanel>
                        </Grid>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button Content="Salvar Tarefas" Style="{StaticResource PrimaryButton}" Click="SaveTasks_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="TipsPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18">
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8BD;" Style="{StaticResource PanelTitleIcon}" />
                                        <TextBlock Text="Dicas" Style="{StaticResource PanelTitleText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Guarde links úteis de pesquisa, reservas, blogs e referências da viagem." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Button Content="+  Nova Dica" Style="{StaticResource SecondaryButton}" Click="AddTip_Click" />
                                <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" Margin="10,0,0,0" ToolTip="Voltar para visão geral" />
                            </StackPanel>
                        </Grid>

                        <ListBox x:Name="TipsList"
                                 Grid.Row="1"
                                 ItemsSource="{Binding Tips}"
                                 SelectedItem="{Binding SelectedTip}"
                                 PreviewKeyDown="TipsList_PreviewKeyDown"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0,0,0,5" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemChrome"
                                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                                        BorderThickness="1"
                                                        Background="{StaticResource PanelBackground}"
                                                        CornerRadius="8"
                                                        Padding="6">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#BFE4DE" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#BFE4DE" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="30">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>

                                        <Grid Margin="0,0,10,0">
                                            <Grid x:Name="TipReadView"
                                                  Background="Transparent"
                                                  MouseLeftButtonDown="TipReadView_MouseLeftButtonDown">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="0.22*" />
                                                    <ColumnDefinition Width="0.78*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBlock Text="{Binding Title}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           Margin="0,0,10,0" />
                                                <Button x:Name="TipLinkButton"
                                                        Grid.Column="1"
                                                        Style="{StaticResource LinkButton}"
                                                        Click="OpenTipLink_Click"
                                                        ToolTip="Abrir link"
                                                        VerticalAlignment="Center">
                                                    <TextBlock Text="{Binding Url}"
                                                               FontSize="12"
                                                                Foreground="{StaticResource AccentBrush}"
                                                                TextTrimming="CharacterEllipsis" />
                                                </Button>
                                                <TextBlock x:Name="TipPlainText"
                                                           Grid.Column="1"
                                                           Text="{Binding Url}"
                                                           FontSize="12"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           TextTrimming="CharacterEllipsis"
                                                           VerticalAlignment="Center"
                                                           Visibility="Collapsed" />
                                            </Grid>

                                            <Grid x:Name="TipEditView"
                                                  Visibility="Collapsed"
                                                  LostKeyboardFocus="TipEditView_LostKeyboardFocus"
                                                  PreviewKeyDown="TipEditView_PreviewKeyDown">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="0.22*" />
                                                    <ColumnDefinition Width="0.78*" />
                                                </Grid.ColumnDefinitions>
                                                <TextBox Text="{Binding Title, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12"
                                                         FontWeight="SemiBold"
                                                         Padding="5,2"
                                                         Margin="0,0,6,0"
                                                         BorderBrush="{StaticResource BorderBrushSoft}"
                                                         Background="{StaticResource InputBackground}" />
                                                <TextBox Grid.Column="1"
                                                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                                         FontSize="12"
                                                         Padding="5,2"
                                                         Foreground="{StaticResource AccentBrush}"
                                                         BorderBrush="{StaticResource BorderBrushSoft}"
                                                         Background="{StaticResource InputBackground}" />
                                            </Grid>
                                        </Grid>

                                        <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="✎"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    Margin="0,0,6,0"
                                                    ToolTip="Editar nome e link"
                                                    Click="EditTipCard_Click" />
                                            <Button Content="×"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    ToolTip="Excluir dica"
                                                    Click="DeleteTipCard_Click" />
                                        </StackPanel>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding HasValidUrl}" Value="False">
                                            <Setter TargetName="TipPlainText" Property="Visibility" Value="Visible" />
                                            <Setter TargetName="TipLinkButton" Property="Visibility" Value="Collapsed" />
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter TargetName="TipReadView" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="TipEditView" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button Content="Salvar Dicas" Style="{StaticResource PrimaryButton}" Click="SaveTips_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="MapPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18">
                <Border Style="{StaticResource Card}">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE707;" Style="{StaticResource PanelTitleIcon}" />
                                        <TextBlock Text="Mapa" Style="{StaticResource PanelTitleText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Informe o link público do Google My Maps e visualize o mapa da viagem." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Button Content="Abrir no navegador" Style="{StaticResource SecondaryButton}" Click="OpenMyMaps_Click" />
                                <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" Margin="10,0,0,0" ToolTip="Voltar para visão geral" />
                            </StackPanel>
                        </Grid>

                        <Grid Grid.Row="1">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <StackPanel>
                                    <TextBlock Text="Link público do Google My Maps" Style="{StaticResource Caption}" />
                                    <TextBox x:Name="MapUrlBox"
                                             Text="{Binding MyMapsUrl, UpdateSourceTrigger=PropertyChanged}"
                                             Padding="10"
                                             Margin="0,4,0,0"
                                             LostKeyboardFocus="MapUrlBox_LostKeyboardFocus"
                                             KeyDown="MapUrlBox_KeyDown" />
                                </StackPanel>
                                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Bottom" Margin="12,0,0,0">
                                    <Button Content="Salvar URL" Style="{StaticResource PrimaryButton}" Click="SaveMap_Click" />
                                </StackPanel>
                            </Grid>

                            <Border Grid.Row="1" Background="#DDE8DF" CornerRadius="8" ClipToBounds="True">
                                <Grid>
                                    <wv2:WebView2 x:Name="MainMapBrowser" />
                                    <TextBlock x:Name="MainMapPlaceholder"
                                               Text="Cole aqui o link público do Google My Maps para exibir o mapa."
                                               TextWrapping="Wrap"
                                               TextAlignment="Center"
                                               Foreground="{StaticResource MutedTextBrush}"
                                               HorizontalAlignment="Center"
                                               VerticalAlignment="Center"
                                               Margin="24" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Grid>
                </Border>
            </Grid>

            <Grid x:Name="FilesPanel" Grid.Row="1" Visibility="Collapsed" Margin="24,22,24,18">
                <Border Style="{StaticResource Card}"
                        AllowDrop="True"
                        DragOver="FilesPanel_DragOver"
                        Drop="FilesPanel_Drop">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto" />
                            <RowDefinition Height="*" />
                            <RowDefinition Height="Auto" />
                        </Grid.RowDefinitions>

                        <Grid Grid.Row="0" Margin="0,0,0,18">
                            <StackPanel>
                                <Grid Margin="0,0,0,2">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE8B7;" Style="{StaticResource PanelTitleIcon}" />
                                        <TextBlock Text="Arquivos" Style="{StaticResource PanelTitleText}" />
                                    </StackPanel>
                                </Grid>
                                <TextBlock Text="Anexe arquivos da viagem. Eles serão copiados para a pasta da viagem." Foreground="{StaticResource MutedTextBrush}" Margin="0,4,0,0" />
                            </StackPanel>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Top">
                                <Button Content="+  Anexar arquivos" Style="{StaticResource SecondaryButton}" Click="AttachFiles_Click" />
                                <Button Content="‹" Style="{StaticResource ArrowButton}" Click="ShowOverview_Click" Margin="10,0,0,0" ToolTip="Voltar para visão geral" />
                            </StackPanel>
                        </Grid>

                        <ListBox x:Name="AttachmentsList"
                                 Grid.Row="1"
                                 ItemsSource="{Binding Attachments}"
                                 SelectedItem="{Binding SelectedAttachment}"
                                 PreviewKeyDown="AttachmentsGrid_PreviewKeyDown"
                                 PreviewMouseLeftButtonDown="AttachmentsList_PreviewMouseLeftButtonDown"
                                 PreviewMouseMove="AttachmentsList_PreviewMouseMove"
                                 MouseDoubleClick="AttachmentsList_MouseDoubleClick"
                                 DragOver="AttachmentsList_DragOver"
                                 Drop="AttachmentsList_Drop"
                                 BorderThickness="0"
                                 Background="Transparent"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Margin" Value="0,0,0,5" />
                                    <Setter Property="Padding" Value="0" />
                                    <Setter Property="HorizontalContentAlignment" Value="Stretch" />
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <Border x:Name="ItemChrome"
                                                        BorderBrush="{StaticResource BorderBrushSoft}"
                                                        BorderThickness="1"
                                                        Background="{StaticResource PanelBackground}"
                                                        CornerRadius="8"
                                                        Padding="9,8">
                                                    <ContentPresenter />
                                                </Border>
                                                <ControlTemplate.Triggers>
                                                    <Trigger Property="IsSelected" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="Background" Value="{StaticResource AccentSoftBrush}" />
                                                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#BFE4DE" />
                                                    </Trigger>
                                                    <Trigger Property="IsMouseOver" Value="True">
                                                        <Setter TargetName="ItemChrome" Property="BorderBrush" Value="#BFE4DE" />
                                                    </Trigger>
                                                </ControlTemplate.Triggers>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid MinHeight="42">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="46" />
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <Border Width="34" Height="36" CornerRadius="5" Background="#F7F9F8" HorizontalAlignment="Left">
                                            <Image Width="28" Height="28" VerticalAlignment="Center" HorizontalAlignment="Center">
                                                <Image.Source>
                                                    <MultiBinding Converter="{StaticResource AttachmentIconConverter}">
                                                        <Binding Path="File" />
                                                        <Binding Path="DataContext.TripPath" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                    </MultiBinding>
                                                </Image.Source>
                                            </Image>
                                        </Border>
                                        <Grid Grid.Column="1" Margin="0,0,14,0" VerticalAlignment="Center">
                                            <StackPanel x:Name="AttachmentReadStack" VerticalAlignment="Center">
                                                <Button x:Name="AttachmentReadView"
                                                        Style="{StaticResource LinkButton}"
                                                        ToolTip="Abrir arquivo"
                                                        PreviewMouseLeftButtonDown="AttachmentFileLink_PreviewMouseLeftButtonDown"
                                                        Click="OpenAttachment_Click">
                                                    <TextBlock Text="{Binding File}"
                                                               FontSize="14"
                                                               FontWeight="SemiBold"
                                                               Foreground="{StaticResource AccentBrush}"
                                                               TextTrimming="CharacterEllipsis" />
                                                </Button>
                                                <TextBlock x:Name="AttachmentMetadataView"
                                                           Foreground="{StaticResource MutedTextBrush}"
                                                           FontSize="12"
                                                           Margin="0,1,0,0">
                                                    <TextBlock.Text>
                                                        <MultiBinding Converter="{StaticResource AttachmentMetadataConverter}">
                                                            <Binding Path="File" />
                                                            <Binding Path="DataContext.TripPath" RelativeSource="{RelativeSource AncestorType=Window}" />
                                                        </MultiBinding>
                                                    </TextBlock.Text>
                                                </TextBlock>
                                            </StackPanel>
                                            <TextBox x:Name="AttachmentEditView"
                                                     Text="{Binding File, UpdateSourceTrigger=PropertyChanged}"
                                                     FontSize="13"
                                                     FontWeight="SemiBold"
                                                     Padding="5,2"
                                                     BorderBrush="{StaticResource BorderBrushSoft}"
                                                     Background="{StaticResource InputBackground}"
                                                     Visibility="Collapsed"
                                                     LostKeyboardFocus="AttachmentEditView_LostKeyboardFocus"
                                                     PreviewKeyDown="AttachmentEditView_PreviewKeyDown" />
                                        </Grid>
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                                            <Button Content="✎"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    Margin="0,0,6,0"
                                                    ToolTip="Renomear arquivo"
                                                    Click="RenameAttachment_Click" />
                                            <Button Content="×"
                                                    Style="{StaticResource SecondaryButton}"
                                                    Width="28"
                                                    Height="28"
                                                    Padding="0"
                                                    ToolTip="Excluir arquivo"
                                                    Click="DeleteAttachment_Click" />
                                        </StackPanel>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <DataTrigger Binding="{Binding IsEditing}" Value="True">
                                            <Setter TargetName="AttachmentReadStack" Property="Visibility" Value="Collapsed" />
                                            <Setter TargetName="AttachmentEditView" Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>

                        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,18,0,0">
                            <Button Content="Salvar Arquivos" Style="{StaticResource PrimaryButton}" Click="SaveAttachments_Click" />
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="2" Background="{StaticResource PanelBackground}" BorderBrush="{StaticResource BorderBrushSoft}" BorderThickness="0,1,0,0">
                <Grid Margin="24,0">
                    <TextBlock Text="☁  Salvo automaticamente" VerticalAlignment="Center" Foreground="{StaticResource MutedTextBrush}" />
                    <TextBlock Text="{Binding StatusMessage}" VerticalAlignment="Center" HorizontalAlignment="Right" Foreground="{StaticResource MutedTextBrush}" />
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>
